@model WebApplication1.Models.InventoryPosition

@{
    ViewData["Title"] = "Inventory Position Details";
    var today          = DateTime.Today;
    bool isExpired     = Model.ExpiryDate.HasValue && Model.ExpiryDate.Value.Date < today;
    bool isExpiringSoon = Model.ExpiryDate.HasValue && !isExpired && Model.ExpiryDate.Value.Date <= today.AddDays(30);
    bool isLowStock    = Model.QuantityOnHand.HasValue && Model.SafetyStock.HasValue && Model.QuantityOnHand <= Model.SafetyStock;
}

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-7">

            <nav aria-label="breadcrumb" class="mb-3">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index" class="text-decoration-none">Dashboard</a></li>
                    <li class="breadcrumb-item"><a asp-action="Index" class="text-decoration-none">Inventory</a></li>
                    <li class="breadcrumb-item active">Details</li>
                </ol>
            </nav>

            <div class="detail-card">
                <!-- Card Header -->
                <div class="card-header d-flex justify-content-between align-items-center"
                     style="background: linear-gradient(135deg, #198754 0%, #146c43 100%);">
                    <div class="d-flex align-items-center gap-3">
                        <div class="bg-white bg-opacity-25 rounded-circle d-flex align-items-center justify-content-center"
                             style="width:50px;height:50px;">
                            <i class="bi bi-boxes fs-4"></i>
                        </div>
                        <div>
                            <h5 class="mb-0 fw-bold">@(Model.Item?.ItemName ?? "Inventory Position")</h5>
                            <small class="opacity-75">Inventory ID: @Model.InventoryId</small>
                        </div>
                    </div>
                    <div class="d-flex gap-1 flex-wrap justify-content-end">
                        @if (isLowStock)
                        {
                            <span class="badge bg-danger badge-status">
                                <i class="bi bi-exclamation-triangle-fill me-1"></i>Low Stock
                            </span>
                        }
                        @if (isExpired)
                        {
                            <span class="badge bg-danger badge-status">
                                <i class="bi bi-x-circle-fill me-1"></i>Expired
                            </span>
                        }
                        else if (isExpiringSoon)
                        {
                            <span class="badge bg-warning text-dark badge-status">
                                <i class="bi bi-clock-fill me-1"></i>Expiring Soon
                            </span>
                        }
                    </div>
                </div>

                <!-- Detail Rows -->
                <div class="card-body p-0">
                    <div class="detail-row">
                        <span class="detail-label"><i class="bi bi-hash me-2"></i>Inventory ID</span>
                        <span class="detail-value">@Model.InventoryId</span>
                    </div>
                    <div class="detail-row">
                        <span class="detail-label"><i class="bi bi-capsule me-2"></i>Item</span>
                        <span class="detail-value fw-semibold">@(Model.Item?.ItemName ?? "—")</span>
                    </div>
                    <div class="detail-row">
                        <span class="detail-label"><i class="bi bi-hospital me-2"></i>Facility</span>
                        <span class="detail-value">@(Model.Facility?.Name ?? "—")</span>
                    </div>
                    <div class="detail-row">
                        <span class="detail-label"><i class="bi bi-boxes me-2"></i>Storage Zone</span>
                        <span class="detail-value">@(Model.Zone?.Name ?? "—")</span>
                    </div>
                    <div class="detail-row">
                        <span class="detail-label"><i class="bi bi-upc-scan me-2"></i>Lot ID</span>
                        <span class="detail-value">
                            @if (!string.IsNullOrEmpty(Model.LotId))
                            {
                                <span class="badge bg-secondary badge-status">@Model.LotId</span>
                            }
                            else
                            {
                                <span class="text-muted">—</span>
                            }
                        </span>
                    </div>
                    <div class="detail-row">
                        <span class="detail-label"><i class="bi bi-123 me-2"></i>Quantity on Hand</span>
                        <span class="detail-value">
                            <span class="fw-semibold">@(Model.QuantityOnHand?.ToString("N2") ?? "—")</span>
                            @if (isLowStock)
                            {
                                <span class="badge bg-danger ms-2" style="font-size:0.65rem;">
                                    <i class="bi bi-exclamation-triangle-fill me-1"></i>Low Stock
                                </span>
                            }
                        </span>
                    </div>
                    <div class="detail-row">
                        <span class="detail-label"><i class="bi bi-shield-check me-2"></i>Safety Stock</span>
                        <span class="detail-value">@(Model.SafetyStock?.ToString("N2") ?? "—")</span>
                    </div>
                    <div class="detail-row">
                        <span class="detail-label"><i class="bi bi-calendar-event me-2"></i>Expiry Date</span>
                        <span class="detail-value">
                            @if (Model.ExpiryDate.HasValue)
                            {
                                if (isExpired)
                                {
                                    <span class="text-danger fw-semibold">
                                        <i class="bi bi-x-circle-fill me-1"></i>@Model.ExpiryDate.Value.ToString("dd MMM yyyy")
                                    </span>
                                    <span class="badge bg-danger ms-1">Expired</span>
                                }
                                else if (isExpiringSoon)
                                {
                                    <span class="text-warning fw-semibold">
                                        <i class="bi bi-clock-fill me-1"></i>@Model.ExpiryDate.Value.ToString("dd MMM yyyy")
                                    </span>
                                    <span class="badge bg-warning text-dark ms-1">Expiring Soon</span>
                                }
                                else
                                {
                                    <span class="text-success">
                                        <i class="bi bi-check-circle me-1"></i>@Model.ExpiryDate.Value.ToString("dd MMM yyyy")
                                    </span>
                                }
                            }
                            else
                            {
                                <span class="text-muted">—</span>
                            }
                        </span>
                    </div>
                </div>

                <!-- Footer Actions -->
                <div class="card-footer bg-white border-top py-3 px-4 d-flex gap-2">
                    <a asp-action="Edit" asp-route-id="@Model.InventoryId" class="btn btn-warning text-white fw-semibold">
                        <i class="bi bi-pencil me-1"></i>Edit
                    </a>
                    <a asp-action="Index" class="btn btn-light">
                        <i class="bi bi-arrow-left me-1"></i>Back to List
                    </a>
                </div>
            </div>

        </div>
    </div>
</div>
