@model WebApplication1.Models.InventoryPosition

@{
    ViewData["Title"] = "Edit Inventory Position";
}

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-7">

            <nav aria-label="breadcrumb" class="mb-3">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index" class="text-decoration-none">Dashboard</a></li>
                    <li class="breadcrumb-item"><a asp-action="Index" class="text-decoration-none">Inventory</a></li>
                    <li class="breadcrumb-item active">Edit</li>
                </ol>
            </nav>

            <div class="form-card">
                <div class="card-header edit-header d-flex align-items-center gap-2">
                    <i class="bi bi-pencil-square fs-5"></i>
                    <h5 class="mb-0 fw-semibold">Edit Inventory Position</h5>
                </div>
                <div class="card-body p-4">
                    <form asp-action="Edit">
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 rounded-3 small mb-3"></div>
                        <input type="hidden" asp-for="InventoryId" />

                        <div class="row g-3">
                            <div class="col-md-12">
                                <label asp-for="ItemId" class="form-label">Item <span class="text-danger">*</span></label>
                                <select asp-for="ItemId" class="form-select" asp-items="ViewBag.ItemId">
                                    <option value="">-- Select Item --</option>
                                </select>
                                <span asp-validation-for="ItemId" class="text-danger small"></span>
                            </div>

                            <div class="col-md-6">
                                <label asp-for="FacilityId" class="form-label">Facility</label>
                                <select asp-for="FacilityId" class="form-select" asp-items="ViewBag.FacilityId">
                                    <option value="">-- Select Facility --</option>
                                </select>
                                <span asp-validation-for="FacilityId" class="text-danger small"></span>
                            </div>

                            <div class="col-md-6">
                                <label asp-for="ZoneId" class="form-label">Storage Zone</label>
                                <select asp-for="ZoneId" class="form-select" asp-items="ViewBag.ZoneId">
                                    <option value="">-- Select Zone --</option>
                                </select>
                                <span asp-validation-for="ZoneId" class="text-danger small"></span>
                            </div>

                            <div class="col-md-12">
                                <label asp-for="LotId" class="form-label">Lot ID</label>
                                <input asp-for="LotId" class="form-control" />
                                <span asp-validation-for="LotId" class="text-danger small"></span>
                            </div>

                            <div class="col-md-6">
                                <label asp-for="QuantityOnHand" class="form-label">Quantity on Hand</label>
                                <input asp-for="QuantityOnHand" class="form-control" type="number" step="0.01" min="0" />
                                <span asp-validation-for="QuantityOnHand" class="text-danger small"></span>
                            </div>

                            <div class="col-md-6">
                                <label asp-for="SafetyStock" class="form-label">Safety Stock</label>
                                <input asp-for="SafetyStock" class="form-control" type="number" step="0.01" min="0" />
                                <span asp-validation-for="SafetyStock" class="text-danger small"></span>
                            </div>

                            <div class="col-md-6">
                                <label asp-for="ExpiryDate" class="form-label">Expiry Date</label>
                                <input asp-for="ExpiryDate" class="form-control" type="date"
                                       value="@Model.ExpiryDate?.ToString("yyyy-MM-dd")" />
                                <span asp-validation-for="ExpiryDate" class="text-danger small"></span>
                            </div>
                        </div>

                        <div class="d-flex gap-2 mt-4">
                            <button type="submit" class="btn btn-warning px-4 fw-semibold text-white">
                                <i class="bi bi-save me-1"></i>Save Changes
                            </button>
                            <a asp-action="Index" class="btn btn-light px-4">
                                <i class="bi bi-arrow-left me-1"></i>Cancel
                            </a>
                        </div>
                    </form>
                </div>
            </div>

        </div>
    </div>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}
