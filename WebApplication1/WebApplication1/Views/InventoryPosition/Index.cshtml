@model IEnumerable<WebApplication1.Models.InventoryPosition>

@{
    ViewData["Title"] = "Inventory Positions";
    var today = DateTime.Today;
    var totalPositions  = Model.Count();
    var lowStockCount   = Model.Count(x => x.QuantityOnHand.HasValue && x.SafetyStock.HasValue && x.QuantityOnHand <= x.SafetyStock);
    var expiredCount    = Model.Count(x => x.ExpiryDate.HasValue && x.ExpiryDate.Value.Date < today);
    var expiringSoon    = Model.Count(x => x.ExpiryDate.HasValue && x.ExpiryDate.Value.Date >= today && x.ExpiryDate.Value.Date <= today.AddDays(30));
}

<div class="container-fluid py-4 px-4">

    <!-- Page Header -->
    <div class="page-header mb-4" style="background: linear-gradient(135deg, #198754 0%, #146c43 100%);">
        <div class="d-flex justify-content-between align-items-center flex-wrap gap-3">
            <div>
                <h2 class="mb-1"><i class="bi bi-boxes me-2"></i>Inventory Positions</h2>
                <nav aria-label="breadcrumb">
                    <ol class="breadcrumb mb-0">
                        <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Dashboard</a></li>
                        <li class="breadcrumb-item active">Inventory</li>
                    </ol>
                </nav>
            </div>
            <a asp-action="Create" class="btn btn-light fw-semibold px-4 shadow-sm">
                <i class="bi bi-plus-lg me-1"></i>Add Position
            </a>
        </div>
    </div>

    <!-- Alerts -->
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show rounded-3 mb-4 shadow-sm" role="alert">
            <i class="bi bi-check-circle-fill me-2"></i>@TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (TempData["SuccessUpdate"] != null)
    {
        <div class="alert alert-info alert-dismissible fade show rounded-3 mb-4 shadow-sm" role="alert">
            <i class="bi bi-pencil-fill me-2"></i>@TempData["SuccessUpdate"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (TempData["SuccessDelete"] != null)
    {
        <div class="alert alert-warning alert-dismissible fade show rounded-3 mb-4 shadow-sm" role="alert">
            <i class="bi bi-trash-fill me-2"></i>@TempData["SuccessDelete"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <!-- Summary Stats Row -->
    <div class="row g-3 mb-4">
        <div class="col-6 col-md-3">
            <div class="card border-0 shadow-sm rounded-3 text-center py-3">
                <div class="fw-bold fs-4 text-success">@totalPositions</div>
                <div class="small text-muted">Total Positions</div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="card border-0 shadow-sm rounded-3 text-center py-3">
                <div class="fw-bold fs-4 text-danger">@lowStockCount</div>
                <div class="small text-muted">Low Stock</div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="card border-0 shadow-sm rounded-3 text-center py-3">
                <div class="fw-bold fs-4 text-warning">@expiringSoon</div>
                <div class="small text-muted">Expiring Soon (&le;30d)</div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="card border-0 shadow-sm rounded-3 text-center py-3">
                <div class="fw-bold fs-4 text-secondary">@expiredCount</div>
                <div class="small text-muted">Expired</div>
            </div>
        </div>
    </div>

    <!-- Table Card -->
    <div class="data-card">
        <div class="card-header d-flex justify-content-between align-items-center flex-wrap gap-2">
            <span class="fw-semibold text-secondary small">
                <i class="bi bi-list-ul me-1"></i>All Inventory Positions
                <span class="badge bg-success ms-2">@totalPositions</span>
            </span>
            <input type="text" id="searchInput" class="search-box" placeholder="Search inventory..." style="width:260px;">
        </div>

        @if (Model.Any())
        {
            <div class="table-responsive">
                <table class="table" id="inventoryTable">
                    <thead>
                        <tr>
                            <th style="width:50px">#</th>
                            <th>Item Name</th>
                            <th>Facility</th>
                            <th>Zone</th>
                            <th>Lot ID</th>
                            <th>Qty on Hand</th>
                            <th>Safety Stock</th>
                            <th>Expiry Date</th>
                            <th class="text-center" style="width:140px">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @{ int i = 1; }
                        @foreach (var inv in Model)
                        {
                            bool isExpired      = inv.ExpiryDate.HasValue && inv.ExpiryDate.Value.Date < today;
                            bool isExpiringSoon  = inv.ExpiryDate.HasValue && !isExpired && inv.ExpiryDate.Value.Date <= today.AddDays(30);
                            bool isLowStock     = inv.QuantityOnHand.HasValue && inv.SafetyStock.HasValue && inv.QuantityOnHand <= inv.SafetyStock;
                            <tr class="@(isExpired ? "table-danger" : "")">
                                <td class="text-muted">@i</td>
                                <td>
                                    <div class="d-flex align-items-center gap-2">
                                        <div class="avatar-icon bg-success bg-opacity-10 text-success rounded-circle d-flex align-items-center justify-content-center">
                                            <i class="bi bi-capsule"></i>
                                        </div>
                                        <span class="fw-semibold">@(inv.Item?.ItemName ?? "—")</span>
                                    </div>
                                </td>
                                <td>
                                    <i class="bi bi-hospital text-muted me-1"></i>@(inv.Facility?.Name ?? "—")
                                </td>
                                <td>
                                    <i class="bi bi-boxes text-muted me-1"></i>@(inv.Zone?.Name ?? "—")
                                </td>
                                <td>
                                    @if (!string.IsNullOrEmpty(inv.LotId))
                                    {
                                        <span class="badge bg-secondary badge-status">
                                            <i class="bi bi-upc-scan me-1"></i>@inv.LotId
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="text-muted small">—</span>
                                    }
                                </td>
                                <td>
                                    <span class="fw-semibold">@(inv.QuantityOnHand?.ToString("N2") ?? "—")</span>
                                    @if (isLowStock)
                                    {
                                        <span class="badge bg-danger ms-1" style="font-size:0.65rem;">
                                            <i class="bi bi-exclamation-triangle-fill me-1"></i>Low Stock
                                        </span>
                                    }
                                </td>
                                <td>
                                    <span class="text-muted">@(inv.SafetyStock?.ToString("N2") ?? "—")</span>
                                </td>
                                <td>
                                    @if (inv.ExpiryDate.HasValue)
                                    {
                                        if (isExpired)
                                        {
                                            <span class="text-danger fw-semibold">
                                                <i class="bi bi-x-circle-fill me-1"></i>@inv.ExpiryDate.Value.ToString("dd MMM yyyy")
                                            </span>
                                            <span class="badge bg-danger ms-1" style="font-size:0.65rem;">Expired</span>
                                        }
                                        else if (isExpiringSoon)
                                        {
                                            <span class="text-warning fw-semibold">
                                                <i class="bi bi-clock-fill me-1"></i>@inv.ExpiryDate.Value.ToString("dd MMM yyyy")
                                            </span>
                                            <span class="badge bg-warning text-dark ms-1" style="font-size:0.65rem;">
                                                <i class="bi bi-exclamation-circle me-1"></i>Expiring Soon
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="text-success">
                                                <i class="bi bi-check-circle me-1"></i>@inv.ExpiryDate.Value.ToString("dd MMM yyyy")
                                            </span>
                                        }
                                    }
                                    else
                                    {
                                        <span class="text-muted small">—</span>
                                    }
                                </td>
                                <td class="text-center">
                                    <div class="d-flex justify-content-center gap-1">
                                        <a asp-action="Details" asp-route-id="@inv.InventoryId"
                                           class="btn btn-sm btn-outline-info" title="View Details">
                                            <i class="bi bi-eye-fill"></i>
                                        </a>
                                        <a asp-action="Edit" asp-route-id="@inv.InventoryId"
                                           class="btn btn-sm btn-outline-warning" title="Edit">
                                            <i class="bi bi-pencil-fill"></i>
                                        </a>
                                        <a asp-action="Delete" asp-route-id="@inv.InventoryId"
                                           class="btn btn-sm btn-outline-danger" title="Delete">
                                            <i class="bi bi-trash-fill"></i>
                                        </a>
                                    </div>
                                </td>
                            </tr>
                            i++;
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="empty-state">
                <i class="bi bi-boxes"></i>
                <p class="fw-semibold mb-1">No inventory positions found</p>
                <p class="small mb-3">Get started by adding your first inventory position.</p>
                <a asp-action="Create" class="btn btn-success px-4">
                    <i class="bi bi-plus-lg me-1"></i>Add Position
                </a>
            </div>
        }
    </div>
</div>

@section Scripts {
    <script>
        document.getElementById('searchInput').addEventListener('keyup', function () {
            const filter = this.value.toLowerCase();
            document.querySelectorAll('#inventoryTable tbody tr').forEach(row => {
                row.style.display = row.textContent.toLowerCase().includes(filter) ? '' : 'none';
            });
        });
    </script>
}
