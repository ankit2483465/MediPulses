<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - MediPulse</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/WebApplication1.styles.css" asp-append-version="true" />
</head>
<body>
@{
    var userRole = Context.Session.GetString("UserRole") ?? "";
    var isAdmin       = userRole == "Admin";
    var isSupply      = userRole == "Clinical Supply Manager";
    var isPharmacy    = userRole == "Pharmacy Manager";
    var isProcurement = userRole == "Procurement Officer";
    var isColdChain   = userRole == "Cold Chain Operator";
    var isBiomedical  = userRole == "Biomedical Engineer / Device Manager";
    var isNursing     = userRole == "Nursing / Ward Staff";
    var isCompliance  = userRole == "Compliance Officer";

    // Grouped permission helpers
    bool canSeeFacilities  = isAdmin || isSupply || isPharmacy || isProcurement || isColdChain || isBiomedical || isCompliance;
    bool canSeeSuppliers   = isAdmin || isProcurement || isPharmacy || isCompliance;
    bool canSeeZones       = isAdmin || isSupply || isColdChain || isCompliance;
    bool canSeeItems       = isAdmin || isSupply || isPharmacy || isBiomedical || isCompliance;
    bool canSeeMasterData  = canSeeFacilities || canSeeSuppliers || canSeeZones || canSeeItems;

    bool canSeePOs         = isAdmin || isProcurement || isPharmacy || isSupply;
    bool canSeeReceipts    = isAdmin || isProcurement || isPharmacy;
    bool canSeeProcurement = canSeePOs || canSeeReceipts;

    bool canSeeInventory   = isAdmin || isSupply || isPharmacy || isBiomedical || isNursing || isCompliance;

    bool canSeeSensors     = isAdmin || isColdChain;
    bool canSeeTelemetry   = isAdmin || isColdChain || isCompliance;
    bool canSeeColdChain   = canSeeSensors || canSeeTelemetry;

    bool canSeeTransfers   = isAdmin || isSupply || isBiomedical || isProcurement;
    bool canSeeConsumption = isAdmin || isSupply || isNursing || isPharmacy;
    bool canSeeDistrib     = canSeeTransfers || canSeeConsumption;
}
    <header>
        <nav class="navbar navbar-expand-lg navbar-dark glass-nav">
            <div class="container-fluid px-4">
                <a class="navbar-brand fw-bold text-white d-flex align-items-center gap-2"
                   asp-controller="@(isAdmin ? "Admin" : "Home")" asp-action="Index">
                    <i class="bi bi-heart-pulse-fill"></i>
                    <span class="brand-name">MediPulse</span>
                </a>
                <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse"
                        aria-controls="navbarSupportedContent" aria-expanded="false" aria-label="Toggle navigation">
                    <span class="bi bi-list fs-4 text-white"></span>
                </button>
                <div class="navbar-collapse collapse d-lg-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">

                        <!-- Dashboard -->
                        <li class="nav-item">
                            <a class="nav-link text-white-50 hover-link"
                               asp-controller="@(isAdmin ? "Admin" : "Home")" asp-action="Index">
                                <i class="bi bi-speedometer2 me-1"></i>Dashboard
                            </a>
                        </li>

                        <!-- Master Data -->
                        @if (canSeeMasterData)
                        {
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle text-white-50 hover-link" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                    <i class="bi bi-database me-1"></i>Master Data
                                </a>
                                <ul class="dropdown-menu dropdown-menu-dark border-0">
                                    @if (canSeeSuppliers)
                                    {
                                        <li>
                                            <a class="dropdown-item py-2" asp-controller="Supplier" asp-action="Index">
                                                <i class="bi bi-truck me-2 text-info"></i>Suppliers
                                            </a>
                                        </li>
                                    }
                                    @if (canSeeFacilities)
                                    {
                                        <li>
                                            <a class="dropdown-item py-2" asp-controller="Facilities" asp-action="Index">
                                                <i class="bi bi-hospital me-2 text-success"></i>Facilities
                                            </a>
                                        </li>
                                    }
                                    @if (canSeeZones)
                                    {
                                        <li>
                                            <a class="dropdown-item py-2" asp-controller="StorageZones" asp-action="Index">
                                                <i class="bi bi-boxes me-2 text-warning"></i>Storage Zones
                                            </a>
                                        </li>
                                    }
                                    @if (canSeeItems)
                                    {
                                        <li>
                                            <a class="dropdown-item py-2" asp-controller="Item" asp-action="Index">
                                                <i class="bi bi-capsule me-2 text-primary"></i>Items
                                            </a>
                                        </li>
                                    }
                                </ul>
                            </li>
                        }

                        <!-- Procurement -->
                        @if (canSeeProcurement)
                        {
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle text-white-50 hover-link" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                    <i class="bi bi-cart3 me-1"></i>Procurement
                                </a>
                                <ul class="dropdown-menu dropdown-menu-dark border-0">
                                    @if (canSeePOs)
                                    {
                                        <li>
                                            <a class="dropdown-item py-2" asp-controller="PurchaseOrder" asp-action="Index">
                                                <i class="bi bi-file-earmark-text me-2 text-primary"></i>Purchase Orders
                                            </a>
                                        </li>
                                    }
                                    @if (canSeeReceipts)
                                    {
                                        <li>
                                            <a class="dropdown-item py-2" asp-controller="Receipt" asp-action="Index">
                                                <i class="bi bi-receipt me-2 text-success"></i>Receipts
                                            </a>
                                        </li>
                                    }
                                </ul>
                            </li>
                        }

                        <!-- Inventory -->
                        @if (canSeeInventory)
                        {
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle text-white-50 hover-link" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                    <i class="bi bi-archive me-1"></i>Inventory
                                </a>
                                <ul class="dropdown-menu dropdown-menu-dark border-0">
                                    <li>
                                        <a class="dropdown-item py-2" asp-controller="InventoryPosition" asp-action="Index">
                                            <i class="bi bi-bar-chart-steps me-2 text-success"></i>Stock Positions
                                        </a>
                                    </li>
                                </ul>
                            </li>
                        }

                        <!-- Cold Chain -->
                        @if (canSeeColdChain)
                        {
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle text-white-50 hover-link" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                    <i class="bi bi-snow me-1"></i>Cold Chain
                                </a>
                                <ul class="dropdown-menu dropdown-menu-dark border-0">
                                    @if (canSeeSensors)
                                    {
                                        <li>
                                            <a class="dropdown-item py-2" asp-controller="SensorDevice" asp-action="Index">
                                                <i class="bi bi-cpu me-2 text-info"></i>Sensor Devices
                                            </a>
                                        </li>
                                    }
                                    @if (canSeeTelemetry)
                                    {
                                        <li>
                                            <a class="dropdown-item py-2" asp-controller="TelemetryRecord" asp-action="Index">
                                                <i class="bi bi-thermometer-half me-2 text-warning"></i>Telemetry
                                            </a>
                                        </li>
                                    }
                                </ul>
                            </li>
                        }

                        <!-- Distribution -->
                        @if (canSeeDistrib)
                        {
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle text-white-50 hover-link" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                    <i class="bi bi-arrow-left-right me-1"></i>Distribution
                                </a>
                                <ul class="dropdown-menu dropdown-menu-dark border-0">
                                    @if (canSeeTransfers)
                                    {
                                        <li>
                                            <a class="dropdown-item py-2" asp-controller="TransferOrder" asp-action="Index">
                                                <i class="bi bi-arrow-left-right me-2 text-warning"></i>Transfer Orders
                                            </a>
                                        </li>
                                    }
                                    @if (canSeeConsumption)
                                    {
                                        <li>
                                            <a class="dropdown-item py-2" asp-controller="ConsumptionRecord" asp-action="Index">
                                                <i class="bi bi-bag-check me-2 text-success"></i>Consumption
                                            </a>
                                        </li>
                                    }
                                </ul>
                            </li>
                        }

                    </ul>

                    <!-- Right side: role badge + logout/login -->
                    <ul class="navbar-nav align-items-center gap-2">
                        @if (!string.IsNullOrEmpty(userRole))
                        {
                            <li class="nav-item">
                                <span class="badge text-white px-3 py-2" style="background:rgba(255,255,255,0.12); border:1px solid rgba(255,255,255,0.2); border-radius:8px; font-size:0.75rem;">
                                    <i class="bi bi-person-badge me-1"></i>@userRole
                                </span>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link nav-login" asp-controller="Account" asp-action="Logout">
                                    <i class="bi bi-box-arrow-right me-1"></i>Logout
                                </a>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="nav-link nav-login" asp-controller="Account" asp-action="Login">
                                    <i class="bi bi-box-arrow-in-right me-1"></i>Login
                                </a>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <main role="main">
        @RenderBody()
    </main>

    <footer class="glass-footer text-white-50 text-center py-3">
        <div class="container">
            <i class="bi bi-heart-pulse-fill text-danger me-1"></i>
            &copy; 2026 MediPulse &mdash; Clinical Logistics &amp; Inventory Intelligence Platform
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
