@model WebApplication1.Models.Supplier

@{
    ViewData["Title"] = "Supplier Details";
    var typeClass   = Model.SupplierType switch { "Manufacturer" => "bg-primary", "Distributor" => "bg-info text-dark", "3PL" => "bg-secondary", _ => "bg-secondary" };
    var statusClass = Model.Status == "Active" ? "bg-success" : "bg-danger";
    var statusIcon  = Model.Status == "Active" ? "bi-check-circle-fill" : "bi-x-circle-fill";
}

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-md-7 col-lg-6">

            <nav aria-label="breadcrumb" class="mb-3">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index" class="text-decoration-none">Dashboard</a></li>
                    <li class="breadcrumb-item"><a asp-action="Index" class="text-decoration-none">Suppliers</a></li>
                    <li class="breadcrumb-item active">Details</li>
                </ol>
            </nav>

            <div class="detail-card">
                <!-- Card Header -->
                <div class="card-header d-flex justify-content-between align-items-center">
                    <div class="d-flex align-items-center gap-3">
                        <div class="bg-white bg-opacity-25 rounded-circle d-flex align-items-center justify-content-center"
                             style="width:50px;height:50px;">
                            <i class="bi bi-truck fs-4"></i>
                        </div>
                        <div>
                            <h5 class="mb-0 fw-bold">@Model.Name</h5>
                            <small class="opacity-75">Supplier ID: @Model.SupplierId</small>
                        </div>
                    </div>
                    <span class="badge @statusClass badge-status">
                        <i class="bi @statusIcon me-1"></i>@Model.Status
                    </span>
                </div>

                <!-- Detail Rows -->
                <div class="card-body p-0">
                    <div class="detail-row">
                        <span class="detail-label"><i class="bi bi-hash me-2"></i>Supplier ID</span>
                        <span class="detail-value">@Model.SupplierId</span>
                    </div>
                    <div class="detail-row">
                        <span class="detail-label"><i class="bi bi-building me-2"></i>Name</span>
                        <span class="detail-value fw-semibold">@Model.Name</span>
                    </div>
                    <div class="detail-row">
                        <span class="detail-label"><i class="bi bi-tag me-2"></i>Supplier Type</span>
                        <span class="detail-value">
                            <span class="badge @typeClass badge-status">@Model.SupplierType</span>
                        </span>
                    </div>
                    <div class="detail-row">
                        <span class="detail-label"><i class="bi bi-activity me-2"></i>Status</span>
                        <span class="detail-value">
                            <span class="badge @statusClass badge-status">
                                <i class="bi @statusIcon me-1"></i>@Model.Status
                            </span>
                        </span>
                    </div>
                </div>

                <!-- Footer Actions -->
                <div class="card-footer bg-white border-top py-3 px-4 d-flex gap-2">
                    <a asp-action="Edit" asp-route-id="@Model.SupplierId" class="btn btn-warning text-white fw-semibold">
                        <i class="bi bi-pencil me-1"></i>Edit
                    </a>
                    <a asp-action="Index" class="btn btn-light">
                        <i class="bi bi-arrow-left me-1"></i>Back to List
                    </a>
                </div>
            </div>

        </div>
    </div>
</div>
