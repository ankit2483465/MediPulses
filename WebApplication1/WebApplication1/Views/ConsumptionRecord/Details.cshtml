@model WebApplication1.Models.ConsumptionRecord

@{
    ViewData["Title"] = "Consumption Record Details";
}

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6">

            <nav aria-label="breadcrumb" class="mb-3">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index" class="text-decoration-none">Dashboard</a></li>
                    <li class="breadcrumb-item"><a asp-action="Index" class="text-decoration-none">Consumption Records</a></li>
                    <li class="breadcrumb-item active">Details</li>
                </ol>
            </nav>

            <div class="detail-card">
                <!-- Card Header -->
                <div class="card-header d-flex justify-content-between align-items-center"
                     style="background: linear-gradient(135deg, #fd7e14 0%, #dc6a0e 100%);">
                    <div class="d-flex align-items-center gap-3">
                        <div class="bg-white bg-opacity-25 rounded-circle d-flex align-items-center justify-content-center"
                             style="width:50px;height:50px;">
                            <i class="bi bi-bag-check fs-4"></i>
                        </div>
                        <div>
                            <h5 class="mb-0 fw-bold">Consumption Record #@Model.ConsumptionId</h5>
                            <small class="opacity-75">
                                @if (Model.Timestamp.HasValue)
                                {
                                    @Model.Timestamp.Value.ToString("MMM dd, yyyy HH:mm")
                                }
                                else
                                {
                                    <span>No timestamp recorded</span>
                                }
                            </small>
                        </div>
                    </div>
                    <span class="badge bg-white text-dark badge-status fw-semibold">
                        <i class="bi bi-bag-check me-1 text-warning"></i>Consumption
                    </span>
                </div>

                <!-- Detail Rows -->
                <div class="card-body p-0">
                    <div class="detail-row">
                        <span class="detail-label"><i class="bi bi-hash me-2"></i>Consumption ID</span>
                        <span class="detail-value fw-semibold">#@Model.ConsumptionId</span>
                    </div>
                    <div class="detail-row">
                        <span class="detail-label"><i class="bi bi-hospital me-2"></i>Facility</span>
                        <span class="detail-value fw-semibold">@(Model.Facility?.Name ?? "—")</span>
                    </div>
                    <div class="detail-row">
                        <span class="detail-label"><i class="bi bi-grid me-2"></i>Ward</span>
                        <span class="detail-value">
                            @if (!string.IsNullOrEmpty(Model.WardId))
                            {
                                <span class="badge bg-secondary badge-status">@Model.WardId</span>
                            }
                            else
                            {
                                <span class="text-muted">—</span>
                            }
                        </span>
                    </div>
                    <div class="detail-row">
                        <span class="detail-label"><i class="bi bi-capsule me-2"></i>Item</span>
                        <span class="detail-value fw-semibold">@(Model.Item?.ItemName ?? "—")</span>
                    </div>
                    @if (Model.Item?.Category != null)
                    {
                        <div class="detail-row">
                            <span class="detail-label"><i class="bi bi-tag me-2"></i>Item Category</span>
                            <span class="detail-value">@Model.Item.Category</span>
                        </div>
                    }
                    <div class="detail-row">
                        <span class="detail-label"><i class="bi bi-123 me-2"></i>Quantity Used</span>
                        <span class="detail-value">
                            <span class="fw-semibold fs-5">@Model.QuantityUsed</span>
                            @if (Model.Item?.UnitOfMeasure != null)
                            {
                                <small class="text-muted ms-1">@Model.Item.UnitOfMeasure</small>
                            }
                        </span>
                    </div>
                    <div class="detail-row">
                        <span class="detail-label"><i class="bi bi-person me-2"></i>Used By</span>
                        <span class="detail-value">
                            @if (Model.UsedByNavigation != null)
                            {
                                <div class="d-flex align-items-center gap-2">
                                    <div class="avatar-icon bg-primary bg-opacity-10 text-primary rounded-circle d-flex align-items-center justify-content-center">
                                        <i class="bi bi-person"></i>
                                    </div>
                                    <div>
                                        <span class="fw-semibold">@Model.UsedByNavigation.Name</span>
                                        @if (Model.UsedByNavigation.Role != null)
                                        {
                                            <small class="text-muted ms-1">(@Model.UsedByNavigation.Role)</small>
                                        }
                                    </div>
                                </div>
                            }
                            else
                            {
                                <span class="text-muted">—</span>
                            }
                        </span>
                    </div>
                    <div class="detail-row">
                        <span class="detail-label"><i class="bi bi-clock me-2"></i>Timestamp</span>
                        <span class="detail-value">
                            @if (Model.Timestamp.HasValue)
                            {
                                <span class="fw-semibold">@Model.Timestamp.Value.ToString("dddd, MMMM dd, yyyy")</span>
                                <small class="text-muted ms-2">@Model.Timestamp.Value.ToString("HH:mm:ss")</small>
                            }
                            else
                            {
                                <span class="text-muted">—</span>
                            }
                        </span>
                    </div>
                </div>

                <!-- Footer Actions -->
                <div class="card-footer bg-white border-top py-3 px-4 d-flex gap-2">
                    <a asp-action="Edit" asp-route-id="@Model.ConsumptionId"
                       class="btn btn-warning text-white fw-semibold">
                        <i class="bi bi-pencil me-1"></i>Edit
                    </a>
                    <a asp-action="Delete" asp-route-id="@Model.ConsumptionId"
                       class="btn btn-outline-danger">
                        <i class="bi bi-trash me-1"></i>Delete
                    </a>
                    <a asp-action="Index" class="btn btn-light">
                        <i class="bi bi-arrow-left me-1"></i>Back to List
                    </a>
                </div>
            </div>

        </div>
    </div>
</div>
