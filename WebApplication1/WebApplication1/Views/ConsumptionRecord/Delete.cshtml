@model WebApplication1.Models.ConsumptionRecord

@{
    ViewData["Title"] = "Delete Consumption Record";
}

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-md-7 col-lg-5">

            <nav aria-label="breadcrumb" class="mb-3">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index" class="text-decoration-none">Dashboard</a></li>
                    <li class="breadcrumb-item"><a asp-action="Index" class="text-decoration-none">Consumption Records</a></li>
                    <li class="breadcrumb-item active text-danger">Delete</li>
                </ol>
            </nav>

            <div class="delete-card">
                <div class="card-header d-flex align-items-center gap-2">
                    <i class="bi bi-exclamation-triangle-fill fs-5"></i>
                    <h5 class="mb-0 fw-semibold">Confirm Deletion</h5>
                </div>
                <div class="card-body p-4">
                    <div class="alert alert-danger d-flex align-items-center gap-2 rounded-3 mb-3">
                        <i class="bi bi-exclamation-circle-fill fs-5 flex-shrink-0"></i>
                        <div><strong>Warning!</strong> This action cannot be undone.</div>
                    </div>

                    <p class="text-muted mb-3 small">You are about to permanently delete the following consumption record:</p>

                    <div class="bg-light rounded-3 p-3 mb-4">
                        <div class="d-flex align-items-center gap-3 mb-3">
                            <div class="avatar-icon bg-danger bg-opacity-10 text-danger rounded-circle d-flex align-items-center justify-content-center">
                                <i class="bi bi-bag-check"></i>
                            </div>
                            <div>
                                <div class="fw-bold">Consumption Record #@Model.ConsumptionId</div>
                                <small class="text-muted">@(Model.Item?.ItemName ?? "Unknown Item")</small>
                            </div>
                        </div>
                        <div class="d-flex align-items-center gap-2 mb-2">
                            <span class="text-muted small fw-semibold" style="min-width:100px;">Facility:</span>
                            <span class="fw-semibold small">@(Model.Facility?.Name ?? "—")</span>
                        </div>
                        @if (!string.IsNullOrEmpty(Model.WardId))
                        {
                            <div class="d-flex align-items-center gap-2 mb-2">
                                <span class="text-muted small fw-semibold" style="min-width:100px;">Ward:</span>
                                <span class="fw-semibold small">@Model.WardId</span>
                            </div>
                        }
                        <div class="d-flex align-items-center gap-2 mb-2">
                            <span class="text-muted small fw-semibold" style="min-width:100px;">Qty Used:</span>
                            <span class="fw-semibold small">@Model.QuantityUsed</span>
                        </div>
                        <div class="d-flex align-items-center gap-2 mb-2">
                            <span class="text-muted small fw-semibold" style="min-width:100px;">Used By:</span>
                            <span class="fw-semibold small">@(Model.UsedByNavigation?.Name ?? "—")</span>
                        </div>
                        @if (Model.Timestamp.HasValue)
                        {
                            <div class="d-flex align-items-center gap-2">
                                <span class="text-muted small fw-semibold" style="min-width:100px;">Timestamp:</span>
                                <span class="small text-muted">@Model.Timestamp.Value.ToString("MMM dd, yyyy HH:mm")</span>
                            </div>
                        }
                    </div>

                    <form asp-action="Delete">
                        <input type="hidden" asp-for="ConsumptionId" />
                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-danger px-4 fw-semibold">
                                <i class="bi bi-trash me-1"></i>Yes, Delete
                            </button>
                            <a asp-action="Index" class="btn btn-light px-4">
                                <i class="bi bi-arrow-left me-1"></i>Cancel
                            </a>
                        </div>
                    </form>
                </div>
            </div>

        </div>
    </div>
</div>
