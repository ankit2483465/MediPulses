@model WebApplication1.Models.User

<style>
    .edit-page-wrap {
        min-height: calc(100vh - 120px);
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 2rem 1rem;
    }
    .edit-card {
        width: 100%;
        max-width: 520px;
        background: #fff;
        border-radius: 20px;
        box-shadow: 0 8px 40px rgba(0,0,0,0.12);
        overflow: hidden;
        border: none;
    }
    .edit-card-header {
        background: linear-gradient(135deg, #7c3aed 0%, #6d28d9 100%);
        padding: 1.75rem 2rem 1.5rem;
        position: relative;
        overflow: hidden;
    }
    .edit-card-header::before {
        content: '';
        position: absolute;
        width: 180px; height: 180px;
        background: rgba(255,255,255,0.06);
        border-radius: 50%;
        top: -60px; right: -40px;
    }
    .edit-card-header .header-icon {
        width: 48px; height: 48px;
        border-radius: 14px;
        background: rgba(255,255,255,0.15);
        display: flex; align-items: center; justify-content: center;
        font-size: 1.4rem; color: #fff;
        margin-bottom: 0.75rem;
    }
    .edit-card-header h5 {
        font-size: 1.2rem; font-weight: 800;
        color: #fff; margin: 0;
        letter-spacing: -0.02em;
    }
    .edit-card-header p {
        color: rgba(255,255,255,0.65);
        font-size: 0.83rem; margin: 0.25rem 0 0;
    }
    .edit-card-body { padding: 2rem; }
    .user-info-strip {
        background: #f5f3ff;
        border: 1px solid #ede9fe;
        border-radius: 12px;
        padding: 0.85rem 1.1rem;
        display: flex; align-items: center; gap: 0.85rem;
        margin-bottom: 1.5rem;
    }
    .user-info-avatar {
        width: 42px; height: 42px;
        border-radius: 12px;
        background: linear-gradient(135deg, #7c3aed, #8b5cf6);
        display: flex; align-items: center; justify-content: center;
        font-size: 1rem; font-weight: 700; color: #fff;
        flex-shrink: 0;
    }
    .user-info-name  { font-size: 0.9rem; font-weight: 700; color: #3730a3; }
    .user-info-email { font-size: 0.78rem; color: #6b7280; }
    .form-label-custom {
        font-size: 0.8rem; font-weight: 700;
        text-transform: uppercase; letter-spacing: 0.05em;
        color: #6b7280; margin-bottom: 0.45rem;
    }
    .form-select-custom {
        border-radius: 10px;
        border: 1.5px solid #e2e8f0;
        padding: 0.65rem 1rem;
        font-size: 0.9rem;
        color: #344767;
        transition: border-color 0.2s, box-shadow 0.2s;
        width: 100%;
        background-color: #fff;
    }
    .form-select-custom:focus {
        border-color: #7c3aed;
        box-shadow: 0 0 0 3px rgba(124,58,237,0.12);
        outline: none;
    }
    .btn-save {
        background: linear-gradient(135deg, #7c3aed, #6d28d9);
        color: #fff; border: none;
        border-radius: 10px;
        padding: 0.65rem 1.5rem;
        font-size: 0.9rem; font-weight: 700;
        transition: opacity 0.2s, box-shadow 0.2s;
        letter-spacing: 0.01em;
    }
    .btn-save:hover { opacity: 0.9; box-shadow: 0 6px 20px rgba(124,58,237,0.4); color: #fff; }
    .btn-back {
        background: #f3f4f6; color: #374151; border: none;
        border-radius: 10px;
        padding: 0.65rem 1.25rem;
        font-size: 0.9rem; font-weight: 600;
        transition: background 0.15s;
        text-decoration: none;
    }
    .btn-back:hover { background: #e5e7eb; color: #374151; }
</style>

<div class="edit-page-wrap">
    <div class="edit-card">
        <div class="edit-card-header">
            <div class="header-icon"><i class="bi bi-person-gear"></i></div>
            <h5>Assign Role</h5>
            <p>Update the clinical role for this user account.</p>
        </div>

        <div class="edit-card-body">
            @{
                var initial = string.IsNullOrEmpty(Model.Name) ? "?" : Model.Name[0].ToString().ToUpper();
            }
            <div class="user-info-strip">
                <div class="user-info-avatar">@initial</div>
                <div>
                    <div class="user-info-name">@Model.Name</div>
                    <div class="user-info-email">@Model.Email</div>
                </div>
            </div>

            <form asp-action="Edit" method="post">
                <input type="hidden" asp-for="UserId" />
                <input type="hidden" asp-for="Name" />
                <input type="hidden" asp-for="Email" />

                <div class="mb-4">
                    <label class="form-label-custom">Select Clinical Role</label>
                    <select asp-for="Role" class="form-select-custom">
                        <option value="">-- Choose a role --</option>
                        @foreach (var role in ViewBag.Roles)
                        {
                            <option value="@role">@role</option>
                        }
                    </select>
                </div>

                <div class="d-flex justify-content-between align-items-center">
                    <a asp-action="Index" class="btn-back">
                        <i class="bi bi-arrow-left me-1"></i> Back
                    </a>
                    <button type="submit" class="btn-save">
                        <i class="bi bi-check2 me-1"></i> Save Changes
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>
