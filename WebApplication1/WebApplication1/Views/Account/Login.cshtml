@{
    Layout = "_LayoutAuth";
    ViewData["Title"] = "Login";
}

<div class="auth-page">
    <div class="auth-left d-none d-lg-flex">
        <div class="auth-brand-panel">
            <div class="mb-4">
                <i class="bi bi-heart-pulse-fill auth-brand-icon"></i>
            </div>
            <h1 class="auth-brand-title">MediPulse</h1>
            <p class="auth-brand-subtitle">Clinical Logistics &amp; Inventory Intelligence Platform</p>
            <div class="auth-features mt-5">
                <div class="auth-feature-item">
                    <i class="bi bi-shield-check-fill text-info me-3"></i>
                    <span>Role-Based Secure Access</span>
                </div>
                <div class="auth-feature-item">
                    <i class="bi bi-bar-chart-line-fill text-success me-3"></i>
                    <span>Real-Time Inventory Intelligence</span>
                </div>
                <div class="auth-feature-item">
                    <i class="bi bi-thermometer-half text-warning me-3"></i>
                    <span>Cold Chain Monitoring</span>
                </div>
                <div class="auth-feature-item">
                    <i class="bi bi-bell-fill text-danger me-3"></i>
                    <span>Expiry &amp; Stockout Alerts</span>
                </div>
            </div>
        </div>
    </div>

    <div class="auth-right">
        <div class="auth-form-wrapper">

            <div class="text-center mb-4 d-lg-none">
                <i class="bi bi-heart-pulse-fill text-danger fs-1"></i>
                <h4 class="fw-bold mt-2" style="color:#0f2d5c;">MediPulse</h4>
            </div>

            <div class="auth-form-card">
                <div class="text-center mb-4">
                    <div class="auth-icon-circle mx-auto mb-3">
                        <i class="bi bi-shield-lock-fill"></i>
                    </div>
                    <h4 class="fw-bold text-dark mb-1">Welcome Back</h4>
                    <p class="text-muted small mb-0">Sign in to your MediPulse account</p>
                </div>

                <form asp-action="Login" method="post">
                    @Html.AntiForgeryToken()

                    @if (ViewBag.Message != null)
                    {
                        <div class="alert alert-danger rounded-3 py-2 small mb-3" role="alert">
                            <i class="bi bi-exclamation-triangle-fill me-2"></i>@ViewBag.Message
                        </div>
                    }

                    <div class="mb-3">
                        <label for="emailInput" class="form-label fw-semibold text-dark small">Email Address</label>
                        <div class="input-group">
                            <span class="input-group-text auth-input-icon"><i class="bi bi-envelope-fill"></i></span>
                            <input name="email" type="email" class="form-control auth-input" id="emailInput" placeholder="Enter Your Email" required />
                        </div>
                    </div>

                    <div class="mb-3">
                        <label for="passwordInput" class="form-label fw-semibold text-dark small">Password</label>
                        <div class="input-group">
                            <span class="input-group-text auth-input-icon"><i class="bi bi-lock-fill"></i></span>
                            <input name="password" type="password" class="form-control auth-input" id="passwordInput" placeholder="••••••••" required />
                        </div>
                    </div>

                    <div class="d-flex justify-content-between align-items-center mb-4">
                        <div class="form-check mb-0">
                            <input class="form-check-input" type="checkbox" id="rememberMe">
                            <label class="form-check-label text-muted small" for="rememberMe">Remember me</label>
                        </div>
                        <a href="#" class="text-muted small text-decoration-none">Forgot password?</a>
                    </div>

                    <button type="submit" class="btn auth-submit-btn w-100 py-2 fw-bold">
                        <i class="bi bi-box-arrow-in-right me-2"></i>Sign In
                    </button>
                </form>

                <hr class="my-4 text-muted">
                <p class="text-center text-muted small mb-0">
                    New to MediPulse?
                    <a asp-action="Signup" class="fw-semibold text-decoration-none auth-link">Create an account</a>
                </p>
            </div>

            <p class="text-center text-muted small mt-4">
                &copy; 2026 MediPulse &mdash; Clinical Logistics Platform
            </p>
        </div>
    </div>
</div>
