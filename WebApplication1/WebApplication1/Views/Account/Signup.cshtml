@model WebApplication1.Models.User
@{
    Layout = "_LayoutAuth";
    ViewData["Title"] = "Register";
}

<div class="auth-page">
    <div class="auth-left d-none d-lg-flex">
        <div class="auth-brand-panel">
            <div class="mb-4">
                <i class="bi bi-heart-pulse-fill auth-brand-icon"></i>
            </div>
            <h1 class="auth-brand-title">MediPulse</h1>
            <p class="auth-brand-subtitle">Clinical Logistics &amp; Inventory Intelligence Platform</p>
            <div class="auth-features mt-5">
                <div class="auth-feature-item">
                    <i class="bi bi-people-fill text-info me-3"></i>
                    <span>8 Specialised Clinical Roles</span>
                </div>
                <div class="auth-feature-item">
                    <i class="bi bi-boxes text-warning me-3"></i>
                    <span>End-to-End Inventory Tracking</span>
                </div>
                <div class="auth-feature-item">
                    <i class="bi bi-cart-check-fill text-success me-3"></i>
                    <span>Procurement &amp; Receiving</span>
                </div>
                <div class="auth-feature-item">
                    <i class="bi bi-graph-up-arrow text-danger me-3"></i>
                    <span>Analytics &amp; Forecasting</span>
                </div>
            </div>
        </div>
    </div>

    <div class="auth-right">
        <div class="auth-form-wrapper">

            <div class="text-center mb-4 d-lg-none">
                <i class="bi bi-heart-pulse-fill text-danger fs-1"></i>
                <h4 class="fw-bold mt-2" style="color:#0f2d5c;">MediPulse</h4>
            </div>

            <div class="auth-form-card">
                <div class="text-center mb-4">
                    <div class="auth-icon-circle mx-auto mb-3">
                        <i class="bi bi-person-plus-fill"></i>
                    </div>
                    <h4 class="fw-bold text-dark mb-1">Create Account</h4>
                    <p class="text-muted small mb-0">Register to access MediPulse</p>
                </div>

                <form asp-action="Signup" method="post">

                    <div class="mb-3">
                        <label asp-for="Name" class="form-label fw-semibold text-dark small">Full Name</label>
                        <div class="input-group">
                            <span class="input-group-text auth-input-icon"><i class="bi bi-person-fill"></i></span>
                            <input asp-for="Name" class="form-control auth-input" placeholder="Enter your name" />
                        </div>
                        <span asp-validation-for="Name" class="text-danger small ms-1"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Email" class="form-label fw-semibold text-dark small">Email Address</label>
                        <div class="input-group">
                            <span class="input-group-text auth-input-icon"><i class="bi bi-envelope-fill"></i></span>
                            <input asp-for="Email" class="form-control auth-input" placeholder="Your Email Address" />
                        </div>
                        <span asp-validation-for="Email" class="text-danger small ms-1"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Phone" class="form-label fw-semibold text-dark small">Phone Number</label>
                        <div class="input-group">
                            <span class="input-group-text auth-input-icon"><i class="bi bi-telephone-fill"></i></span>
                            <input asp-for="Phone" class="form-control auth-input" placeholder="Your Phone Number" />
                        </div>
                        <span asp-validation-for="Phone" class="text-danger small ms-1"></span>
                    </div>

                    <div class="mb-1">
                        <label asp-for="Password" class="form-label fw-semibold text-dark small">Password</label>
                        <div class="input-group">
                            <span class="input-group-text auth-input-icon"><i class="bi bi-lock-fill"></i></span>
                            <input asp-for="Password" type="password" class="form-control auth-input" placeholder="Create Password" />
                        </div>
                    </div>
                    <span asp-validation-for="Password" class="text-danger small ms-1 d-block mb-3"></span>

                    <button type="submit" class="btn auth-submit-btn w-100 py-2 fw-bold mt-2">
                        <i class="bi bi-person-check-fill me-2"></i>Create Account
                    </button>
                </form>

                <hr class="my-4 text-muted">
                <p class="text-center text-muted small mb-0">
                    Already have an account?
                    <a asp-action="Login" class="fw-semibold text-decoration-none auth-link">Sign in</a>
                </p>
            </div>

            <p class="text-center text-muted small mt-4">
                &copy; 2026 MediPulse &mdash; Clinical Logistics Platform
            </p>
        </div>
    </div>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}
