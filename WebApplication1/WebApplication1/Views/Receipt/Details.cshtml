@model WebApplication1.Models.Receipt

@{
    ViewData["Title"] = "Receipt Details";
    var qsClass = Model.QualityStatus switch
    {
        "Accepted" => "bg-success",
        "Rejected" => "bg-danger",
        "On Hold"  => "bg-warning text-dark",
        "Pending"  => "bg-secondary",
        _          => "bg-secondary"
    };
    var qsIcon = Model.QualityStatus switch
    {
        "Accepted" => "bi-check-circle-fill",
        "Rejected" => "bi-x-circle-fill",
        "On Hold"  => "bi-pause-circle-fill",
        "Pending"  => "bi-clock-fill",
        _          => "bi-circle"
    };
}

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-7">

            <nav aria-label="breadcrumb" class="mb-3">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index" class="text-decoration-none">Dashboard</a></li>
                    <li class="breadcrumb-item"><a asp-action="Index" class="text-decoration-none">Receipts</a></li>
                    <li class="breadcrumb-item active">Details</li>
                </ol>
            </nav>

            <div class="detail-card">
                <!-- Card Header -->
                <div class="card-header d-flex justify-content-between align-items-center">
                    <div class="d-flex align-items-center gap-3">
                        <div class="bg-white bg-opacity-25 rounded-circle d-flex align-items-center justify-content-center"
                             style="width:50px;height:50px;">
                            <i class="bi bi-receipt fs-4"></i>
                        </div>
                        <div>
                            <h5 class="mb-0 fw-bold">REC-@Model.ReceiptId</h5>
                            <small class="opacity-75">Receipt Details</small>
                        </div>
                    </div>
                    <span class="badge @qsClass badge-status">
                        <i class="bi @qsIcon me-1"></i>@Model.QualityStatus
                    </span>
                </div>

                <!-- Detail Rows -->
                <div class="card-body p-0">
                    <div class="detail-row">
                        <span class="detail-label"><i class="bi bi-hash me-2"></i>Receipt ID</span>
                        <span class="detail-value fw-semibold">REC-@Model.ReceiptId</span>
                    </div>
                    <div class="detail-row">
                        <span class="detail-label"><i class="bi bi-file-earmark-text me-2"></i>Purchase Order</span>
                        <span class="detail-value">
                            @if (Model.Po != null)
                            {
                                <a asp-controller="PurchaseOrder" asp-action="Details" asp-route-id="@Model.Po.Poid"
                                   class="text-primary text-decoration-none fw-semibold">
                                    PO #@Model.Po.Poid
                                </a>
                            }
                            else
                            {
                                <span class="text-muted fst-italic">Not linked</span>
                            }
                        </span>
                    </div>
                    <div class="detail-row">
                        <span class="detail-label"><i class="bi bi-building me-2"></i>Supplier</span>
                        <span class="detail-value">
                            @if (Model.Po?.Supplier != null)
                            {
                                <span class="fw-semibold">@Model.Po.Supplier.Name</span>
                            }
                            else
                            {
                                <span class="text-muted fst-italic">—</span>
                            }
                        </span>
                    </div>
                    <div class="detail-row">
                        <span class="detail-label"><i class="bi bi-upc-scan me-2"></i>Supplier Lot</span>
                        <span class="detail-value">
                            @if (!string.IsNullOrEmpty(Model.SupplierLot))
                            {
                                <span class="badge bg-light text-dark border badge-status">@Model.SupplierLot</span>
                            }
                            else
                            {
                                <span class="text-muted fst-italic">—</span>
                            }
                        </span>
                    </div>
                    <div class="detail-row">
                        <span class="detail-label"><i class="bi bi-calendar-event me-2"></i>Received Date</span>
                        <span class="detail-value">
                            @(Model.ReceivedDate.HasValue ? Model.ReceivedDate.Value.ToString("MMMM dd, yyyy") : "—")
                        </span>
                    </div>
                    <div class="detail-row">
                        <span class="detail-label"><i class="bi bi-person-fill me-2"></i>Received By</span>
                        <span class="detail-value">
                            @if (Model.ReceivedByNavigation != null)
                            {
                                <span class="fw-semibold">@Model.ReceivedByNavigation.Name</span>
                                <span class="badge bg-light text-dark border badge-status ms-2">@Model.ReceivedByNavigation.Role</span>
                            }
                            else
                            {
                                <span class="text-muted fst-italic">—</span>
                            }
                        </span>
                    </div>
                    <div class="detail-row">
                        <span class="detail-label"><i class="bi bi-shield-check me-2"></i>Quality Status</span>
                        <span class="detail-value">
                            <span class="badge @qsClass badge-status">
                                <i class="bi @qsIcon me-1"></i>@Model.QualityStatus
                            </span>
                        </span>
                    </div>
                </div>

                <!-- Footer Actions -->
                <div class="card-footer bg-white border-top py-3 px-4 d-flex gap-2">
                    <a asp-action="Edit" asp-route-id="@Model.ReceiptId" class="btn btn-warning text-white fw-semibold">
                        <i class="bi bi-pencil me-1"></i>Edit
                    </a>
                    <a asp-action="Delete" asp-route-id="@Model.ReceiptId" class="btn btn-outline-danger">
                        <i class="bi bi-trash me-1"></i>Delete
                    </a>
                    <a asp-action="Index" class="btn btn-light">
                        <i class="bi bi-arrow-left me-1"></i>Back to List
                    </a>
                </div>
            </div>

        </div>
    </div>
</div>
