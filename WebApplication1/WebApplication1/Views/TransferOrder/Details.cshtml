@model WebApplication1.Models.TransferOrder

@{
    ViewData["Title"] = "Transfer Order Details";
    var statusClass = Model.Status switch {
        "Pending"    => "bg-warning text-dark",
        "In Transit" => "bg-info text-dark",
        "Delivered"  => "bg-success",
        "Cancelled"  => "bg-danger",
        _            => "bg-secondary"
    };
    var statusIcon = Model.Status switch {
        "Pending"    => "bi-hourglass-split",
        "In Transit" => "bi-truck",
        "Delivered"  => "bi-check-circle-fill",
        "Cancelled"  => "bi-x-circle-fill",
        _            => "bi-circle"
    };
}

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6">

            <nav aria-label="breadcrumb" class="mb-3">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index" class="text-decoration-none">Dashboard</a></li>
                    <li class="breadcrumb-item"><a asp-action="Index" class="text-decoration-none">Transfer Orders</a></li>
                    <li class="breadcrumb-item active">Details</li>
                </ol>
            </nav>

            <div class="detail-card">
                <!-- Card Header -->
                <div class="card-header d-flex justify-content-between align-items-center"
                     style="background: linear-gradient(135deg, #fd7e14 0%, #dc6a0e 100%);">
                    <div class="d-flex align-items-center gap-3">
                        <div class="bg-white bg-opacity-25 rounded-circle d-flex align-items-center justify-content-center"
                             style="width:50px;height:50px;">
                            <i class="bi bi-arrow-left-right fs-4"></i>
                        </div>
                        <div>
                            <h5 class="mb-0 fw-bold">Transfer Order #@Model.TransferId</h5>
                            <small class="opacity-75">Distribution &amp; Logistics</small>
                        </div>
                    </div>
                    <span class="badge @statusClass badge-status">
                        <i class="bi @statusIcon me-1"></i>@Model.Status
                    </span>
                </div>

                <!-- Detail Rows -->
                <div class="card-body p-0">
                    <div class="detail-row">
                        <span class="detail-label"><i class="bi bi-hash me-2"></i>Transfer ID</span>
                        <span class="detail-value fw-semibold">#@Model.TransferId</span>
                    </div>
                    <div class="detail-row">
                        <span class="detail-label"><i class="bi bi-hospital me-2"></i>From Facility</span>
                        <span class="detail-value">
                            @if (Model.FromFacility != null)
                            {
                                <span class="fw-semibold">@Model.FromFacility.Name</span>
                                @if (!string.IsNullOrEmpty(Model.FromFacility.Region))
                                {
                                    <small class="text-muted ms-1">— @Model.FromFacility.Region</small>
                                }
                            }
                            else
                            {
                                <span class="text-muted">—</span>
                            }
                        </span>
                    </div>
                    <div class="detail-row">
                        <span class="detail-label"><i class="bi bi-hospital me-2"></i>To Facility</span>
                        <span class="detail-value">
                            @if (Model.ToFacility != null)
                            {
                                <span class="fw-semibold">@Model.ToFacility.Name</span>
                                @if (!string.IsNullOrEmpty(Model.ToFacility.Region))
                                {
                                    <small class="text-muted ms-1">— @Model.ToFacility.Region</small>
                                }
                            }
                            else
                            {
                                <span class="text-muted">—</span>
                            }
                        </span>
                    </div>
                    <div class="detail-row">
                        <span class="detail-label"><i class="bi bi-capsule me-2"></i>Item</span>
                        <span class="detail-value fw-semibold">@(Model.Item?.ItemName ?? "—")</span>
                    </div>
                    <div class="detail-row">
                        <span class="detail-label"><i class="bi bi-123 me-2"></i>Quantity</span>
                        <span class="detail-value">
                            <span class="fw-semibold fs-5">@Model.Quantity</span>
                            @if (Model.Item?.UnitOfMeasure != null)
                            {
                                <small class="text-muted ms-1">@Model.Item.UnitOfMeasure</small>
                            }
                        </span>
                    </div>
                    <div class="detail-row">
                        <span class="detail-label"><i class="bi bi-flag me-2"></i>Status</span>
                        <span class="detail-value">
                            <span class="badge @statusClass badge-status">
                                <i class="bi @statusIcon me-1"></i>@Model.Status
                            </span>
                        </span>
                    </div>
                </div>

                <!-- Footer Actions -->
                <div class="card-footer bg-white border-top py-3 px-4 d-flex gap-2">
                    <a asp-action="Edit" asp-route-id="@Model.TransferId"
                       class="btn btn-warning text-white fw-semibold">
                        <i class="bi bi-pencil me-1"></i>Edit
                    </a>
                    <a asp-action="Delete" asp-route-id="@Model.TransferId"
                       class="btn btn-outline-danger">
                        <i class="bi bi-trash me-1"></i>Delete
                    </a>
                    <a asp-action="Index" class="btn btn-light">
                        <i class="bi bi-arrow-left me-1"></i>Back to List
                    </a>
                </div>
            </div>

        </div>
    </div>
</div>
