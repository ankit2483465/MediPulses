@model WebApplication1.Models.TransferOrder

@{
    ViewData["Title"] = "Create Transfer Order";
}

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6">

            <nav aria-label="breadcrumb" class="mb-3">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index" class="text-decoration-none">Dashboard</a></li>
                    <li class="breadcrumb-item"><a asp-action="Index" class="text-decoration-none">Transfer Orders</a></li>
                    <li class="breadcrumb-item active">Create</li>
                </ol>
            </nav>

            <div class="form-card">
                <div class="card-header d-flex align-items-center gap-2"
                     style="background: linear-gradient(135deg, #fd7e14 0%, #dc6a0e 100%);">
                    <i class="bi bi-arrow-left-right fs-5"></i>
                    <h5 class="mb-0 fw-semibold">New Transfer Order</h5>
                </div>
                <div class="card-body p-4">
                    <form asp-action="Create">
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 rounded-3 small mb-3"></div>

                        <div class="mb-3">
                            <label asp-for="FromFacilityId" class="form-label">From Facility <span class="text-danger">*</span></label>
                            <select asp-for="FromFacilityId" class="form-select"
                                    asp-items="ViewBag.FromFacilityId">
                                <option value="">-- Select Source Facility --</option>
                            </select>
                            <span asp-validation-for="FromFacilityId" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="ToFacilityId" class="form-label">To Facility <span class="text-danger">*</span></label>
                            <select asp-for="ToFacilityId" class="form-select"
                                    asp-items="ViewBag.ToFacilityId">
                                <option value="">-- Select Destination Facility --</option>
                            </select>
                            <span asp-validation-for="ToFacilityId" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="ItemId" class="form-label">Item <span class="text-danger">*</span></label>
                            <select asp-for="ItemId" class="form-select"
                                    asp-items="ViewBag.ItemId">
                                <option value="">-- Select Item --</option>
                            </select>
                            <span asp-validation-for="ItemId" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Quantity" class="form-label">Quantity <span class="text-danger">*</span></label>
                            <input asp-for="Quantity" class="form-control" type="number"
                                   step="0.01" min="0" placeholder="e.g. 100.00" />
                            <span asp-validation-for="Quantity" class="text-danger small"></span>
                        </div>

                        <div class="mb-4">
                            <label asp-for="Status" class="form-label">Status <span class="text-danger">*</span></label>
                            <select asp-for="Status" class="form-select">
                                <option value="">-- Select Status --</option>
                                <option value="Pending">Pending</option>
                                <option value="In Transit">In Transit</option>
                                <option value="Delivered">Delivered</option>
                                <option value="Cancelled">Cancelled</option>
                            </select>
                            <span asp-validation-for="Status" class="text-danger small"></span>
                        </div>

                        <div class="d-flex gap-2">
                            <button type="submit" class="btn px-4 fw-semibold text-white" style="background-color:#fd7e14;">
                                <i class="bi bi-check2 me-1"></i>Create Order
                            </button>
                            <a asp-action="Index" class="btn btn-light px-4">
                                <i class="bi bi-arrow-left me-1"></i>Cancel
                            </a>
                        </div>
                    </form>
                </div>
            </div>

        </div>
    </div>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}
