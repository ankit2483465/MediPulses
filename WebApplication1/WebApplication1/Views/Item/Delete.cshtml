@model WebApplication1.Models.Item

@{
    ViewData["Title"] = "Delete Item";
    var catClass = Model.Category switch {
        "Pharma"     => "bg-primary",
        "Device"     => "bg-warning text-dark",
        "Consumable" => "bg-success",
        _            => "bg-secondary"
    };
    var catIcon = Model.Category switch {
        "Pharma"     => "bi-capsule",
        "Device"     => "bi-device-hdd",
        "Consumable" => "bi-bag-check",
        _            => "bi-tag"
    };
}

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-md-7 col-lg-5">

            <nav aria-label="breadcrumb" class="mb-3">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index" class="text-decoration-none">Dashboard</a></li>
                    <li class="breadcrumb-item"><a asp-action="Index" class="text-decoration-none">Items</a></li>
                    <li class="breadcrumb-item active text-danger">Delete</li>
                </ol>
            </nav>

            <div class="delete-card">
                <div class="card-header d-flex align-items-center gap-2">
                    <i class="bi bi-exclamation-triangle-fill fs-5"></i>
                    <h5 class="mb-0 fw-semibold">Confirm Deletion</h5>
                </div>
                <div class="card-body p-4">
                    <div class="alert alert-danger d-flex align-items-center gap-2 rounded-3 mb-3">
                        <i class="bi bi-exclamation-circle-fill fs-5 flex-shrink-0"></i>
                        <div><strong>Warning!</strong> This action cannot be undone.</div>
                    </div>

                    <p class="text-muted mb-3 small">You are about to permanently delete the following item:</p>

                    <div class="bg-light rounded-3 p-3 mb-4">
                        <div class="d-flex align-items-center gap-3 mb-2">
                            <div class="avatar-icon bg-danger bg-opacity-10 text-danger rounded-circle d-flex align-items-center justify-content-center">
                                <i class="bi bi-capsule"></i>
                            </div>
                            <div>
                                <div class="fw-bold">@Model.ItemName</div>
                                <small class="text-muted">ID: @Model.ItemId &bull; @(Model.UnitOfMeasure ?? "No unit specified")</small>
                            </div>
                        </div>
                        @if (!string.IsNullOrEmpty(Model.Category))
                        {
                            <span class="badge @catClass badge-status">
                                <i class="bi @catIcon me-1"></i>@Model.Category
                            </span>
                        }
                        @if (!string.IsNullOrEmpty(Model.StorageRequirement))
                        {
                            <span class="badge bg-secondary badge-status ms-1">
                                <i class="bi bi-thermometer me-1"></i>@Model.StorageRequirement
                            </span>
                        }
                    </div>

                    <form asp-action="Delete">
                        <input type="hidden" asp-for="ItemId" />
                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-danger px-4 fw-semibold">
                                <i class="bi bi-trash me-1"></i>Yes, Delete
                            </button>
                            <a asp-action="Index" class="btn btn-light px-4">
                                <i class="bi bi-arrow-left me-1"></i>Cancel
                            </a>
                        </div>
                    </form>
                </div>
            </div>

        </div>
    </div>
</div>
