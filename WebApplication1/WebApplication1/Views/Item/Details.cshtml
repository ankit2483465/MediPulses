@model WebApplication1.Models.Item

@{
    ViewData["Title"] = "Item Details";
    var catClass = Model.Category switch {
        "Pharma"     => "bg-primary",
        "Device"     => "bg-warning text-dark",
        "Consumable" => "bg-success",
        _            => "bg-secondary"
    };
    var catIcon = Model.Category switch {
        "Pharma"     => "bi-capsule",
        "Device"     => "bi-device-hdd",
        "Consumable" => "bi-bag-check",
        _            => "bi-tag"
    };
    var storClass = Model.StorageRequirement switch {
        "Ambient"      => "bg-warning text-dark",
        "Refrigerated" => "bg-info text-dark",
        "Freezer"      => "bg-primary",
        "Controlled"   => "bg-danger",
        _              => "bg-secondary"
    };
    var storIcon = Model.StorageRequirement switch {
        "Ambient"      => "bi-sun",
        "Refrigerated" => "bi-thermometer-half",
        "Freezer"      => "bi-snow",
        "Controlled"   => "bi-shield-lock",
        _              => "bi-thermometer"
    };
}

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-md-7 col-lg-6">

            <nav aria-label="breadcrumb" class="mb-3">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index" class="text-decoration-none">Dashboard</a></li>
                    <li class="breadcrumb-item"><a asp-action="Index" class="text-decoration-none">Items</a></li>
                    <li class="breadcrumb-item active">Details</li>
                </ol>
            </nav>

            <div class="detail-card">
                <!-- Card Header -->
                <div class="card-header d-flex justify-content-between align-items-center"
                     style="background: linear-gradient(135deg, #198754 0%, #146c43 100%);">
                    <div class="d-flex align-items-center gap-3">
                        <div class="bg-white bg-opacity-25 rounded-circle d-flex align-items-center justify-content-center"
                             style="width:50px;height:50px;">
                            <i class="bi bi-capsule fs-4"></i>
                        </div>
                        <div>
                            <h5 class="mb-0 fw-bold">@Model.ItemName</h5>
                            <small class="opacity-75">Item ID: @Model.ItemId</small>
                        </div>
                    </div>
                    @if (!string.IsNullOrEmpty(Model.Category))
                    {
                        <span class="badge @catClass badge-status">
                            <i class="bi @catIcon me-1"></i>@Model.Category
                        </span>
                    }
                </div>

                <!-- Detail Rows -->
                <div class="card-body p-0">
                    <div class="detail-row">
                        <span class="detail-label"><i class="bi bi-hash me-2"></i>Item ID</span>
                        <span class="detail-value">@Model.ItemId</span>
                    </div>
                    <div class="detail-row">
                        <span class="detail-label"><i class="bi bi-capsule me-2"></i>Item Name</span>
                        <span class="detail-value fw-semibold">@Model.ItemName</span>
                    </div>
                    <div class="detail-row">
                        <span class="detail-label"><i class="bi bi-tag me-2"></i>Category</span>
                        <span class="detail-value">
                            @if (!string.IsNullOrEmpty(Model.Category))
                            {
                                <span class="badge @catClass badge-status">
                                    <i class="bi @catIcon me-1"></i>@Model.Category
                                </span>
                            }
                            else
                            {
                                <span class="text-muted">—</span>
                            }
                        </span>
                    </div>
                    <div class="detail-row">
                        <span class="detail-label"><i class="bi bi-rulers me-2"></i>Unit of Measure</span>
                        <span class="detail-value">@(Model.UnitOfMeasure ?? "—")</span>
                    </div>
                    <div class="detail-row">
                        <span class="detail-label"><i class="bi bi-thermometer me-2"></i>Storage Requirement</span>
                        <span class="detail-value">
                            @if (!string.IsNullOrEmpty(Model.StorageRequirement))
                            {
                                <span class="badge @storClass badge-status">
                                    <i class="bi @storIcon me-1"></i>@Model.StorageRequirement
                                </span>
                            }
                            else
                            {
                                <span class="text-muted">—</span>
                            }
                        </span>
                    </div>
                </div>

                <!-- Footer Actions -->
                <div class="card-footer bg-white border-top py-3 px-4 d-flex gap-2">
                    <a asp-action="Edit" asp-route-id="@Model.ItemId" class="btn btn-warning text-white fw-semibold">
                        <i class="bi bi-pencil me-1"></i>Edit
                    </a>
                    <a asp-action="Index" class="btn btn-light">
                        <i class="bi bi-arrow-left me-1"></i>Back to List
                    </a>
                </div>
            </div>

        </div>
    </div>
</div>
