@model WebApplication1.Models.TelemetryRecord

@{
    ViewData["Title"] = "Log Telemetry Reading";
}

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6">

            <nav aria-label="breadcrumb" class="mb-3">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index" class="text-decoration-none">Dashboard</a></li>
                    <li class="breadcrumb-item"><a asp-action="Index" class="text-decoration-none">Telemetry</a></li>
                    <li class="breadcrumb-item active">Log Reading</li>
                </ol>
            </nav>

            <div class="form-card">
                <div class="card-header d-flex align-items-center gap-2"
                     style="background: linear-gradient(135deg, #0dcaf0 0%, #0aa2c0 100%);">
                    <i class="bi bi-thermometer-half fs-5"></i>
                    <h5 class="mb-0 fw-semibold">Log New Telemetry Reading</h5>
                </div>
                <div class="card-body p-4">
                    <form asp-action="Create">
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 rounded-3 small mb-3"></div>

                        <div class="mb-3">
                            <label asp-for="SensorId" class="form-label fw-semibold">
                                <i class="bi bi-cpu me-1 text-info"></i>Sensor Device <span class="text-danger">*</span>
                            </label>
                            <select asp-for="SensorId" class="form-select"
                                    asp-items="ViewBag.SensorId">
                                <option value="">-- Select Sensor --</option>
                            </select>
                            <span asp-validation-for="SensorId" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Timestamp" class="form-label fw-semibold">
                                <i class="bi bi-clock me-1 text-info"></i>Timestamp <span class="text-danger">*</span>
                            </label>
                            <input asp-for="Timestamp" type="datetime-local" class="form-control"
                                   value="@DateTime.Now.ToString("yyyy-MM-ddTHH:mm")" />
                            <span asp-validation-for="Timestamp" class="text-danger small"></span>
                        </div>

                        <div class="row g-3 mb-3">
                            <div class="col-md-6">
                                <label asp-for="Temperature" class="form-label fw-semibold">
                                    <i class="bi bi-thermometer-half me-1 text-info"></i>Temperature (°C)
                                </label>
                                <div class="input-group">
                                    <input asp-for="Temperature" type="number" step="0.1"
                                           class="form-control" placeholder="e.g. 4.5" />
                                    <span class="input-group-text">°C</span>
                                </div>
                                <span asp-validation-for="Temperature" class="text-danger small"></span>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="Humidity" class="form-label fw-semibold">
                                    <i class="bi bi-droplet-half me-1 text-info"></i>Humidity (%)
                                </label>
                                <div class="input-group">
                                    <input asp-for="Humidity" type="number" step="0.1"
                                           class="form-control" placeholder="e.g. 65.0" />
                                    <span class="input-group-text">%</span>
                                </div>
                                <span asp-validation-for="Humidity" class="text-danger small"></span>
                            </div>
                        </div>

                        <div class="mb-4">
                            <label asp-for="Location" class="form-label fw-semibold">
                                <i class="bi bi-geo-alt me-1 text-info"></i>Location
                            </label>
                            <input asp-for="Location" class="form-control"
                                   placeholder="e.g. Warehouse B, Bay 3 / GPS: 51.5, -0.12" />
                            <span asp-validation-for="Location" class="text-danger small"></span>
                        </div>

                        <!-- Cold Chain Reference Info -->
                        <div class="alert alert-info d-flex gap-2 py-2 rounded-3 mb-4 small">
                            <i class="bi bi-info-circle-fill flex-shrink-0 mt-1"></i>
                            <div>
                                <strong>Cold Chain Thresholds:</strong> Normal range is <strong>2–8°C</strong>.
                                Values above <strong>8°C</strong> trigger an <span class="badge bg-danger">EXCURSION</span> alert.
                                Values between <strong>5–8°C</strong> trigger a <span class="badge bg-warning text-dark">WARNING</span>.
                            </div>
                        </div>

                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-info text-white px-4 fw-semibold">
                                <i class="bi bi-check2 me-1"></i>Log Reading
                            </button>
                            <a asp-action="Index" class="btn btn-light px-4">
                                <i class="bi bi-arrow-left me-1"></i>Cancel
                            </a>
                        </div>
                    </form>
                </div>
            </div>

        </div>
    </div>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}
