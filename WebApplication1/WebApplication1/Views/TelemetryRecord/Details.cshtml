@model WebApplication1.Models.TelemetryRecord

@{
    ViewData["Title"] = "Telemetry Record Details";
    bool isExcursion = Model.Temperature.HasValue && Model.Temperature > 8;
    bool isWarning   = Model.Temperature.HasValue && Model.Temperature > 5 && Model.Temperature <= 8;

    var tempAlertClass  = isExcursion ? "bg-danger" : isWarning ? "bg-warning text-dark" : "bg-success";
    var tempAlertLabel  = isExcursion ? "EXCURSION" : isWarning ? "WARNING" : "NORMAL";

    var typeClass = Model.Sensor?.DeviceType switch {
        "Temp"     => "bg-info text-dark",
        "Humidity" => "bg-primary",
        "GPS"      => "bg-secondary",
        _          => "bg-secondary"
    };
    var typeIcon = Model.Sensor?.DeviceType switch {
        "Temp"     => "bi-thermometer-half",
        "Humidity" => "bi-droplet-half",
        "GPS"      => "bi-geo-alt-fill",
        _          => "bi-cpu"
    };
}

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6">

            <nav aria-label="breadcrumb" class="mb-3">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index" class="text-decoration-none">Dashboard</a></li>
                    <li class="breadcrumb-item"><a asp-action="Index" class="text-decoration-none">Telemetry</a></li>
                    <li class="breadcrumb-item active">Details</li>
                </ol>
            </nav>

            <div class="detail-card">
                <!-- Card Header -->
                <div class="card-header d-flex justify-content-between align-items-center"
                     style="background: linear-gradient(135deg, #0dcaf0 0%, #0aa2c0 100%);">
                    <div class="d-flex align-items-center gap-3">
                        <div class="bg-white bg-opacity-25 rounded-circle d-flex align-items-center justify-content-center"
                             style="width:50px;height:50px;">
                            <i class="bi bi-thermometer-half fs-4"></i>
                        </div>
                        <div>
                            <h5 class="mb-0 fw-bold">Record #@Model.TelemetryId</h5>
                            <small class="opacity-75">
                                @if (Model.SensorId.HasValue)
                                {
                                    <span>Sensor #@Model.SensorId</span>
                                }
                                &bull; @Model.Timestamp?.ToString("dd MMM yyyy HH:mm")
                            </small>
                        </div>
                    </div>
                    @if (Model.Temperature.HasValue)
                    {
                        <span class="badge @tempAlertClass badge-status">@tempAlertLabel</span>
                    }
                </div>

                <!-- Detail Rows -->
                <div class="card-body p-0">
                    <div class="detail-row">
                        <span class="detail-label"><i class="bi bi-hash me-2"></i>Record ID</span>
                        <span class="detail-value">@Model.TelemetryId</span>
                    </div>
                    <div class="detail-row">
                        <span class="detail-label"><i class="bi bi-cpu me-2"></i>Sensor</span>
                        <span class="detail-value">
                            @if (Model.Sensor != null)
                            {
                                <span class="fw-semibold">Sensor #@Model.SensorId</span>
                                <span class="badge @typeClass badge-status ms-2">
                                    <i class="bi @typeIcon me-1"></i>@Model.Sensor.DeviceType
                                </span>
                            }
                            else if (Model.SensorId.HasValue)
                            {
                                <span>Sensor #@Model.SensorId</span>
                            }
                            else
                            {
                                <span class="text-muted">Not assigned</span>
                            }
                        </span>
                    </div>
                    <div class="detail-row">
                        <span class="detail-label"><i class="bi bi-clock me-2"></i>Timestamp</span>
                        <span class="detail-value">@Model.Timestamp?.ToString("dd MMMM yyyy, HH:mm:ss")</span>
                    </div>
                    <div class="detail-row">
                        <span class="detail-label"><i class="bi bi-thermometer-half me-2"></i>Temperature</span>
                        <span class="detail-value">
                            @if (Model.Temperature.HasValue)
                            {
                                <span class="fw-bold fs-5 @(isExcursion ? "text-danger" : isWarning ? "text-warning" : "text-success")">
                                    @Model.Temperature?.ToString("F2") °C
                                </span>
                                <span class="badge @tempAlertClass badge-status ms-2">@tempAlertLabel</span>
                            }
                            else
                            {
                                <span class="text-muted">Not recorded</span>
                            }
                        </span>
                    </div>
                    <div class="detail-row">
                        <span class="detail-label"><i class="bi bi-droplet-half me-2"></i>Humidity</span>
                        <span class="detail-value">
                            @if (Model.Humidity.HasValue)
                            {
                                <span class="fw-semibold">@Model.Humidity?.ToString("F2") %</span>
                            }
                            else
                            {
                                <span class="text-muted">Not recorded</span>
                            }
                        </span>
                    </div>
                    <div class="detail-row">
                        <span class="detail-label"><i class="bi bi-geo-alt me-2"></i>Location</span>
                        <span class="detail-value">
                            @(string.IsNullOrWhiteSpace(Model.Location) ? "Not specified" : Model.Location)
                        </span>
                    </div>
                </div>

                <!-- Cold Chain Status Banner -->
                @if (isExcursion)
                {
                    <div class="mx-4 mb-3">
                        <div class="alert alert-danger d-flex align-items-center gap-2 rounded-3 py-2 mb-0">
                            <i class="bi bi-exclamation-triangle-fill fs-5 flex-shrink-0"></i>
                            <div class="small">
                                <strong>Cold Chain Excursion!</strong> Temperature of @Model.Temperature?.ToString("F1")°C
                                exceeds the safe threshold of 8°C. Immediate action required.
                            </div>
                        </div>
                    </div>
                }
                else if (isWarning)
                {
                    <div class="mx-4 mb-3">
                        <div class="alert alert-warning d-flex align-items-center gap-2 rounded-3 py-2 mb-0">
                            <i class="bi bi-exclamation-circle-fill fs-5 flex-shrink-0"></i>
                            <div class="small">
                                <strong>Temperature Warning.</strong> Temperature of @Model.Temperature?.ToString("F1")°C
                                is approaching the excursion threshold. Monitor closely.
                            </div>
                        </div>
                    </div>
                }

                <!-- Footer Actions -->
                <div class="card-footer bg-white border-top py-3 px-4 d-flex gap-2">
                    <a asp-action="Edit" asp-route-id="@Model.TelemetryId" class="btn btn-warning text-white fw-semibold">
                        <i class="bi bi-pencil me-1"></i>Edit
                    </a>
                    <a asp-action="Index" class="btn btn-light">
                        <i class="bi bi-arrow-left me-1"></i>Back to List
                    </a>
                </div>
            </div>

        </div>
    </div>
</div>
