@model WebApplication1.Models.TelemetryRecord

@{
    ViewData["Title"] = "Edit Telemetry Record";
}

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6">

            <nav aria-label="breadcrumb" class="mb-3">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index" class="text-decoration-none">Dashboard</a></li>
                    <li class="breadcrumb-item"><a asp-action="Index" class="text-decoration-none">Telemetry</a></li>
                    <li class="breadcrumb-item active">Edit</li>
                </ol>
            </nav>

            <div class="form-card">
                <div class="card-header edit-header d-flex align-items-center gap-2">
                    <i class="bi bi-pencil-square fs-5"></i>
                    <h5 class="mb-0 fw-semibold">Edit Telemetry Record</h5>
                </div>
                <div class="card-body p-4">
                    <form asp-action="Edit">
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 rounded-3 small mb-3"></div>
                        <input type="hidden" asp-for="TelemetryId" />

                        <div class="mb-3">
                            <label class="form-label fw-semibold text-muted small">
                                <i class="bi bi-hash me-1"></i>Record ID
                            </label>
                            <div class="form-control bg-light text-muted">#@Model.TelemetryId</div>
                        </div>

                        <div class="mb-3">
                            <label asp-for="SensorId" class="form-label fw-semibold">
                                <i class="bi bi-cpu me-1 text-warning"></i>Sensor Device <span class="text-danger">*</span>
                            </label>
                            <select asp-for="SensorId" class="form-select"
                                    asp-items="ViewBag.SensorId">
                                <option value="">-- Select Sensor --</option>
                            </select>
                            <span asp-validation-for="SensorId" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Timestamp" class="form-label fw-semibold">
                                <i class="bi bi-clock me-1 text-warning"></i>Timestamp <span class="text-danger">*</span>
                            </label>
                            <input asp-for="Timestamp" type="datetime-local" class="form-control"
                                   value="@Model.Timestamp?.ToString("yyyy-MM-ddTHH:mm")" />
                            <span asp-validation-for="Timestamp" class="text-danger small"></span>
                        </div>

                        <div class="row g-3 mb-3">
                            <div class="col-md-6">
                                <label asp-for="Temperature" class="form-label fw-semibold">
                                    <i class="bi bi-thermometer-half me-1 text-warning"></i>Temperature (°C)
                                </label>
                                <div class="input-group">
                                    <input asp-for="Temperature" type="number" step="0.1" class="form-control" />
                                    <span class="input-group-text">°C</span>
                                </div>
                                <span asp-validation-for="Temperature" class="text-danger small"></span>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="Humidity" class="form-label fw-semibold">
                                    <i class="bi bi-droplet-half me-1 text-warning"></i>Humidity (%)
                                </label>
                                <div class="input-group">
                                    <input asp-for="Humidity" type="number" step="0.1" class="form-control" />
                                    <span class="input-group-text">%</span>
                                </div>
                                <span asp-validation-for="Humidity" class="text-danger small"></span>
                            </div>
                        </div>

                        <div class="mb-4">
                            <label asp-for="Location" class="form-label fw-semibold">
                                <i class="bi bi-geo-alt me-1 text-warning"></i>Location
                            </label>
                            <input asp-for="Location" class="form-control" />
                            <span asp-validation-for="Location" class="text-danger small"></span>
                        </div>

                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-warning text-white px-4 fw-semibold">
                                <i class="bi bi-save me-1"></i>Save Changes
                            </button>
                            <a asp-action="Index" class="btn btn-light px-4">
                                <i class="bi bi-arrow-left me-1"></i>Cancel
                            </a>
                        </div>
                    </form>
                </div>
            </div>

        </div>
    </div>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}
