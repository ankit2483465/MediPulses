@model IEnumerable<WebApplication1.Models.TelemetryRecord>

@{
    ViewData["Title"] = "Telemetry Records";
    var excursionCount = Model.Count(t => t.Temperature.HasValue && t.Temperature > 8);
    var warningCount   = Model.Count(t => t.Temperature.HasValue && t.Temperature > 5 && t.Temperature <= 8);
}

<div class="container-fluid py-4 px-4">

    <!-- Page Header -->
    <div class="page-header mb-4" style="background: linear-gradient(135deg, #0dcaf0 0%, #0aa2c0 100%);">
        <div class="d-flex justify-content-between align-items-center flex-wrap gap-3">
            <div>
                <h2 class="mb-1"><i class="bi bi-thermometer-half me-2"></i>Telemetry Records</h2>
                <nav aria-label="breadcrumb">
                    <ol class="breadcrumb mb-0">
                        <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Dashboard</a></li>
                        <li class="breadcrumb-item active">Telemetry</li>
                    </ol>
                </nav>
            </div>
            <a asp-action="Create" class="btn btn-light fw-semibold px-4 shadow-sm">
                <i class="bi bi-plus-lg me-1"></i>Log Reading
            </a>
        </div>
    </div>

    <!-- Alerts -->
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show rounded-3 mb-4 shadow-sm" role="alert">
            <i class="bi bi-check-circle-fill me-2"></i>@TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (TempData["SuccessUpdate"] != null)
    {
        <div class="alert alert-info alert-dismissible fade show rounded-3 mb-4 shadow-sm" role="alert">
            <i class="bi bi-pencil-fill me-2"></i>@TempData["SuccessUpdate"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (TempData["SuccessDelete"] != null)
    {
        <div class="alert alert-warning alert-dismissible fade show rounded-3 mb-4 shadow-sm" role="alert">
            <i class="bi bi-trash-fill me-2"></i>@TempData["SuccessDelete"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <!-- Summary Stats -->
    @if (Model.Any())
    {
        <div class="row g-3 mb-4">
            <div class="col-6 col-md-3">
                <div class="card border-0 shadow-sm rounded-3 text-center py-3">
                    <div class="fs-4 fw-bold text-info">@Model.Count()</div>
                    <div class="small text-muted">Total Readings</div>
                </div>
            </div>
            <div class="col-6 col-md-3">
                <div class="card border-0 shadow-sm rounded-3 text-center py-3">
                    <div class="fs-4 fw-bold text-danger">@excursionCount</div>
                    <div class="small text-muted">Excursions (&gt;8°C)</div>
                </div>
            </div>
            <div class="col-6 col-md-3">
                <div class="card border-0 shadow-sm rounded-3 text-center py-3">
                    <div class="fs-4 fw-bold text-warning">@warningCount</div>
                    <div class="small text-muted">Warnings (5–8°C)</div>
                </div>
            </div>
            <div class="col-6 col-md-3">
                <div class="card border-0 shadow-sm rounded-3 text-center py-3">
                    <div class="fs-4 fw-bold text-success">@Model.Select(t => t.SensorId).Distinct().Count()</div>
                    <div class="small text-muted">Active Sensors</div>
                </div>
            </div>
        </div>
    }

    <!-- Table Card -->
    <div class="data-card">
        <div class="card-header d-flex justify-content-between align-items-center flex-wrap gap-2">
            <span class="fw-semibold text-secondary small">
                <i class="bi bi-list-ul me-1"></i>All Telemetry Records
                <span class="badge bg-info text-dark ms-2">@Model.Count()</span>
            </span>
            <input type="text" id="searchInput" class="search-box" placeholder="Search records..." style="width:260px;">
        </div>

        @if (Model.Any())
        {
            <div class="table-responsive">
                <table class="table" id="telemetryTable">
                    <thead>
                        <tr>
                            <th style="width:50px">#</th>
                            <th>Sensor ID</th>
                            <th>Device Type</th>
                            <th>Timestamp</th>
                            <th class="text-center">Temperature (°C)</th>
                            <th class="text-center">Humidity (%)</th>
                            <th>Location</th>
                            <th class="text-center" style="width:140px">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @{ int i = 1; }
                        @foreach (var item in Model)
                        {
                            var typeClass = item.Sensor?.DeviceType switch {
                                "Temp"     => "bg-info text-dark",
                                "Humidity" => "bg-primary",
                                "GPS"      => "bg-secondary",
                                _          => "bg-secondary"
                            };
                            var typeIcon = item.Sensor?.DeviceType switch {
                                "Temp"     => "bi-thermometer-half",
                                "Humidity" => "bi-droplet-half",
                                "GPS"      => "bi-geo-alt-fill",
                                _          => "bi-cpu"
                            };
                            bool isExcursion = item.Temperature.HasValue && item.Temperature > 8;
                            bool isWarning   = item.Temperature.HasValue && item.Temperature > 5 && item.Temperature <= 8;
                            <tr class="@(isExcursion ? "table-danger" : isWarning ? "table-warning" : "")">
                                <td class="text-muted">@i</td>
                                <td>
                                    <div class="d-flex align-items-center gap-2">
                                        <div class="avatar-icon bg-info bg-opacity-10 text-info rounded-circle d-flex align-items-center justify-content-center">
                                            <i class="bi bi-cpu"></i>
                                        </div>
                                        <span class="fw-semibold">
                                            @(item.SensorId.HasValue ? $"Sensor #{item.SensorId}" : "—")
                                        </span>
                                    </div>
                                </td>
                                <td>
                                    @if (item.Sensor != null)
                                    {
                                        <span class="badge @typeClass badge-status">
                                            <i class="bi @typeIcon me-1"></i>@item.Sensor.DeviceType
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="text-muted">—</span>
                                    }
                                </td>
                                <td>
                                    <i class="bi bi-clock text-muted me-1"></i>
                                    <span class="small">@item.Timestamp?.ToString("dd MMM yyyy HH:mm")</span>
                                </td>
                                <td class="text-center">
                                    @if (item.Temperature.HasValue)
                                    {
                                        <span class="fw-semibold @(isExcursion ? "text-danger" : isWarning ? "text-warning" : "")">
                                            @item.Temperature?.ToString("F1")
                                        </span>
                                        if (isExcursion)
                                        {
                                            <span class="badge bg-danger ms-1">EXCURSION</span>
                                        }
                                        else if (isWarning)
                                        {
                                            <span class="badge bg-warning text-dark ms-1">WARNING</span>
                                        }
                                    }
                                    else
                                    {
                                        <span class="text-muted">—</span>
                                    }
                                </td>
                                <td class="text-center">
                                    @(item.Humidity.HasValue ? item.Humidity?.ToString("F1") : "—")
                                </td>
                                <td>
                                    <i class="bi bi-geo-alt text-muted me-1"></i>
                                    @(string.IsNullOrWhiteSpace(item.Location) ? "—" : item.Location)
                                </td>
                                <td class="text-center">
                                    <div class="d-flex justify-content-center gap-1">
                                        <a asp-action="Details" asp-route-id="@item.TelemetryId"
                                           class="btn btn-sm btn-outline-info" title="View Details">
                                            <i class="bi bi-eye-fill"></i>
                                        </a>
                                        <a asp-action="Edit" asp-route-id="@item.TelemetryId"
                                           class="btn btn-sm btn-outline-warning" title="Edit">
                                            <i class="bi bi-pencil-fill"></i>
                                        </a>
                                        <a asp-action="Delete" asp-route-id="@item.TelemetryId"
                                           class="btn btn-sm btn-outline-danger" title="Delete">
                                            <i class="bi bi-trash-fill"></i>
                                        </a>
                                    </div>
                                </td>
                            </tr>
                            i++;
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="empty-state">
                <i class="bi bi-thermometer-half"></i>
                <p class="fw-semibold mb-1">No telemetry records found</p>
                <p class="small mb-3">Start logging sensor readings to monitor your cold chain.</p>
                <a asp-action="Create" class="btn btn-info text-white px-4">
                    <i class="bi bi-plus-lg me-1"></i>Log Reading
                </a>
            </div>
        }
    </div>
</div>

@section Scripts {
    <script>
        document.getElementById('searchInput').addEventListener('keyup', function () {
            const filter = this.value.toLowerCase();
            document.querySelectorAll('#telemetryTable tbody tr').forEach(row => {
                row.style.display = row.textContent.toLowerCase().includes(filter) ? '' : 'none';
            });
        });
    </script>
}
