@model WebApplication1.Models.TelemetryRecord

@{
    ViewData["Title"] = "Delete Telemetry Record";
    bool isExcursion = Model.Temperature.HasValue && Model.Temperature > 8;
    bool isWarning   = Model.Temperature.HasValue && Model.Temperature > 5 && Model.Temperature <= 8;
    var tempBadgeClass = isExcursion ? "bg-danger" : isWarning ? "bg-warning text-dark" : "bg-success";
    var tempLabel      = isExcursion ? "EXCURSION" : isWarning ? "WARNING" : "NORMAL";

    var typeIcon = Model.Sensor?.DeviceType switch {
        "Temp"     => "bi-thermometer-half",
        "Humidity" => "bi-droplet-half",
        "GPS"      => "bi-geo-alt-fill",
        _          => "bi-cpu"
    };
}

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-md-7 col-lg-5">

            <nav aria-label="breadcrumb" class="mb-3">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index" class="text-decoration-none">Dashboard</a></li>
                    <li class="breadcrumb-item"><a asp-action="Index" class="text-decoration-none">Telemetry</a></li>
                    <li class="breadcrumb-item active text-danger">Delete</li>
                </ol>
            </nav>

            <div class="delete-card">
                <div class="card-header d-flex align-items-center gap-2">
                    <i class="bi bi-exclamation-triangle-fill fs-5"></i>
                    <h5 class="mb-0 fw-semibold">Confirm Deletion</h5>
                </div>
                <div class="card-body p-4">
                    <div class="alert alert-danger d-flex align-items-center gap-2 rounded-3 mb-3">
                        <i class="bi bi-exclamation-circle-fill fs-5 flex-shrink-0"></i>
                        <div><strong>Warning!</strong> This action cannot be undone.</div>
                    </div>

                    <p class="text-muted mb-3 small">You are about to permanently delete the following telemetry record:</p>

                    <div class="bg-light rounded-3 p-3 mb-4">
                        <div class="d-flex align-items-center gap-3 mb-2">
                            <div class="avatar-icon bg-danger bg-opacity-10 text-danger rounded-circle d-flex align-items-center justify-content-center">
                                <i class="bi bi-thermometer-half"></i>
                            </div>
                            <div>
                                <div class="fw-bold">Record #@Model.TelemetryId</div>
                                <small class="text-muted">
                                    @if (Model.SensorId.HasValue)
                                    {
                                        <span>
                                            <i class="bi bi-cpu me-1"></i>Sensor #@Model.SensorId
                                            @if (Model.Sensor != null)
                                            {
                                                <span>
                                                    (<i class="bi @typeIcon me-1"></i>@Model.Sensor.DeviceType)
                                                </span>
                                            }
                                            &bull;
                                        </span>
                                    }
                                    <i class="bi bi-clock me-1"></i>@Model.Timestamp?.ToString("dd MMM yyyy HH:mm")
                                </small>
                            </div>
                        </div>

                        <div class="d-flex flex-wrap gap-2 mt-2">
                            @if (Model.Temperature.HasValue)
                            {
                                <span class="badge bg-light text-dark border">
                                    <i class="bi bi-thermometer-half me-1 text-info"></i>@Model.Temperature?.ToString("F1") °C
                                </span>
                                <span class="badge @tempBadgeClass">@tempLabel</span>
                            }
                            @if (Model.Humidity.HasValue)
                            {
                                <span class="badge bg-light text-dark border">
                                    <i class="bi bi-droplet-half me-1 text-primary"></i>@Model.Humidity?.ToString("F1") %
                                </span>
                            }
                            @if (!string.IsNullOrWhiteSpace(Model.Location))
                            {
                                <span class="badge bg-light text-dark border">
                                    <i class="bi bi-geo-alt me-1"></i>@Model.Location
                                </span>
                            }
                        </div>
                    </div>

                    <form asp-action="Delete">
                        <input type="hidden" asp-for="TelemetryId" />
                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-danger px-4 fw-semibold">
                                <i class="bi bi-trash me-1"></i>Yes, Delete
                            </button>
                            <a asp-action="Index" class="btn btn-light px-4">
                                <i class="bi bi-arrow-left me-1"></i>Cancel
                            </a>
                        </div>
                    </form>
                </div>
            </div>

        </div>
    </div>
</div>
