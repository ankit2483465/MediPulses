@model WebApplication1.Models.PurchaseOrder

@{
    ViewData["Title"] = "Purchase Order Details";
    var statusClass = Model.Status switch
    {
        "Draft"     => "bg-secondary",
        "Submitted" => "bg-primary",
        "Approved"  => "bg-success",
        "Received"  => "bg-info text-dark",
        "Cancelled" => "bg-danger",
        _           => "bg-secondary"
    };
    var statusIcon = Model.Status switch
    {
        "Draft"     => "bi-pencil",
        "Submitted" => "bi-send",
        "Approved"  => "bi-check-circle-fill",
        "Received"  => "bi-inbox-fill",
        "Cancelled" => "bi-x-circle-fill",
        _           => "bi-circle"
    };
}

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-7">

            <nav aria-label="breadcrumb" class="mb-3">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index" class="text-decoration-none">Dashboard</a></li>
                    <li class="breadcrumb-item"><a asp-action="Index" class="text-decoration-none">Purchase Orders</a></li>
                    <li class="breadcrumb-item active">Details</li>
                </ol>
            </nav>

            <div class="detail-card">
                <!-- Card Header -->
                <div class="card-header d-flex justify-content-between align-items-center">
                    <div class="d-flex align-items-center gap-3">
                        <div class="bg-white bg-opacity-25 rounded-circle d-flex align-items-center justify-content-center"
                             style="width:50px;height:50px;">
                            <i class="bi bi-file-earmark-text fs-4"></i>
                        </div>
                        <div>
                            <h5 class="mb-0 fw-bold">PO #@Model.Poid</h5>
                            <small class="opacity-75">Purchase Order Details</small>
                        </div>
                    </div>
                    <span class="badge @statusClass badge-status">
                        <i class="bi @statusIcon me-1"></i>@Model.Status
                    </span>
                </div>

                <!-- Detail Rows -->
                <div class="card-body p-0">
                    <div class="detail-row">
                        <span class="detail-label"><i class="bi bi-hash me-2"></i>PO ID</span>
                        <span class="detail-value fw-semibold">PO #@Model.Poid</span>
                    </div>
                    <div class="detail-row">
                        <span class="detail-label"><i class="bi bi-building me-2"></i>Supplier</span>
                        <span class="detail-value">
                            @if (Model.Supplier != null)
                            {
                                <span class="fw-semibold">@Model.Supplier.Name</span>
                                <span class="badge bg-secondary badge-status ms-2">@Model.Supplier.SupplierType</span>
                            }
                            else
                            {
                                <span class="text-muted fst-italic">Not assigned</span>
                            }
                        </span>
                    </div>
                    <div class="detail-row">
                        <span class="detail-label"><i class="bi bi-calendar-event me-2"></i>Order Date</span>
                        <span class="detail-value">
                            @(Model.OrderDate.HasValue ? Model.OrderDate.Value.ToString("MMMM dd, yyyy") : "—")
                        </span>
                    </div>
                    <div class="detail-row">
                        <span class="detail-label"><i class="bi bi-calendar-check me-2"></i>Expected Delivery</span>
                        <span class="detail-value">
                            @(Model.ExpectedDeliveryDate.HasValue ? Model.ExpectedDeliveryDate.Value.ToString("MMMM dd, yyyy") : "—")
                        </span>
                    </div>
                    <div class="detail-row">
                        <span class="detail-label"><i class="bi bi-activity me-2"></i>Status</span>
                        <span class="detail-value">
                            <span class="badge @statusClass badge-status">
                                <i class="bi @statusIcon me-1"></i>@Model.Status
                            </span>
                        </span>
                    </div>
                    <div class="detail-row">
                        <span class="detail-label"><i class="bi bi-receipt me-2"></i>Receipts</span>
                        <span class="detail-value">
                            <span class="badge bg-primary">@Model.Receipts.Count receipt(s)</span>
                        </span>
                    </div>
                </div>

                <!-- Footer Actions -->
                <div class="card-footer bg-white border-top py-3 px-4 d-flex gap-2">
                    <a asp-action="Edit" asp-route-id="@Model.Poid" class="btn btn-warning text-white fw-semibold">
                        <i class="bi bi-pencil me-1"></i>Edit
                    </a>
                    <a asp-action="Delete" asp-route-id="@Model.Poid" class="btn btn-outline-danger">
                        <i class="bi bi-trash me-1"></i>Delete
                    </a>
                    <a asp-action="Index" class="btn btn-light">
                        <i class="bi bi-arrow-left me-1"></i>Back to List
                    </a>
                </div>
            </div>

        </div>
    </div>
</div>
