@model WebApplication1.Models.StorageZone

@{
    ViewData["Title"] = "Storage Zone Details";
    var tempClass = Model.TemperatureProfile switch { "Ambient" => "bg-warning text-dark", "Refrigerated" => "bg-info text-dark", "Freezer" => "bg-primary", _ => "bg-secondary" };
    var tempIcon  = Model.TemperatureProfile switch { "Ambient" => "bi-sun", "Refrigerated" => "bi-thermometer-half", "Freezer" => "bi-snow", _ => "bi-thermometer" };
}

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-md-7 col-lg-6">

            <nav aria-label="breadcrumb" class="mb-3">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index" class="text-decoration-none">Dashboard</a></li>
                    <li class="breadcrumb-item"><a asp-action="Index" class="text-decoration-none">Storage Zones</a></li>
                    <li class="breadcrumb-item active">Details</li>
                </ol>
            </nav>

            <div class="detail-card">
                <!-- Card Header -->
                <div class="card-header d-flex justify-content-between align-items-center"
                     style="background: linear-gradient(135deg, #0dcaf0 0%, #0aa2c0 100%);">
                    <div class="d-flex align-items-center gap-3">
                        <div class="bg-white bg-opacity-25 rounded-circle d-flex align-items-center justify-content-center"
                             style="width:50px;height:50px;">
                            <i class="bi bi-boxes fs-4"></i>
                        </div>
                        <div>
                            <h5 class="mb-0 fw-bold">@Model.Name</h5>
                            <small class="opacity-75">Zone ID: @Model.ZoneId</small>
                        </div>
                    </div>
                    <span class="badge @tempClass badge-status">
                        <i class="bi @tempIcon me-1"></i>@Model.TemperatureProfile
                    </span>
                </div>

                <!-- Detail Rows -->
                <div class="card-body p-0">
                    <div class="detail-row">
                        <span class="detail-label"><i class="bi bi-hash me-2"></i>Zone ID</span>
                        <span class="detail-value">@Model.ZoneId</span>
                    </div>
                    <div class="detail-row">
                        <span class="detail-label"><i class="bi bi-boxes me-2"></i>Zone Name</span>
                        <span class="detail-value fw-semibold">@Model.Name</span>
                    </div>
                    <div class="detail-row">
                        <span class="detail-label"><i class="bi bi-hospital me-2"></i>Facility</span>
                        <span class="detail-value">@(Model.Facility?.Name ?? "—")</span>
                    </div>
                    <div class="detail-row">
                        <span class="detail-label"><i class="bi bi-thermometer-half me-2"></i>Temperature Profile</span>
                        <span class="detail-value">
                            <span class="badge @tempClass badge-status">
                                <i class="bi @tempIcon me-1"></i>@Model.TemperatureProfile
                            </span>
                        </span>
                    </div>
                    <div class="detail-row">
                        <span class="detail-label"><i class="bi bi-box me-2"></i>Capacity</span>
                        <span class="detail-value fw-semibold">@Model.Capacity <span class="text-muted fw-normal small">units</span></span>
                    </div>
                </div>

                <!-- Footer Actions -->
                <div class="card-footer bg-white border-top py-3 px-4 d-flex gap-2">
                    <a asp-action="Edit" asp-route-id="@Model.ZoneId" class="btn btn-warning text-white fw-semibold">
                        <i class="bi bi-pencil me-1"></i>Edit
                    </a>
                    <a asp-action="Index" class="btn btn-light">
                        <i class="bi bi-arrow-left me-1"></i>Back to List
                    </a>
                </div>
            </div>

        </div>
    </div>
</div>
