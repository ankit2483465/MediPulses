@model WebApplication1.Models.SensorDevice

@{
    ViewData["Title"] = "Sensor Device Details";
    var statusClass = Model.Status switch {
        "Active"      => "bg-success",
        "Inactive"    => "bg-danger",
        "Maintenance" => "bg-warning text-dark",
        _             => "bg-secondary"
    };
    var typeClass = Model.DeviceType switch {
        "Temp"     => "bg-info text-dark",
        "Humidity" => "bg-primary",
        "GPS"      => "bg-secondary",
        _          => "bg-secondary"
    };
    var typeIcon = Model.DeviceType switch {
        "Temp"     => "bi-thermometer-half",
        "Humidity" => "bi-droplet-half",
        "GPS"      => "bi-geo-alt-fill",
        _          => "bi-cpu"
    };
}

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6">

            <nav aria-label="breadcrumb" class="mb-3">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index" class="text-decoration-none">Dashboard</a></li>
                    <li class="breadcrumb-item"><a asp-action="Index" class="text-decoration-none">Sensor Devices</a></li>
                    <li class="breadcrumb-item active">Details</li>
                </ol>
            </nav>

            <div class="detail-card">
                <!-- Card Header -->
                <div class="card-header d-flex justify-content-between align-items-center"
                     style="background: linear-gradient(135deg, #0dcaf0 0%, #0aa2c0 100%);">
                    <div class="d-flex align-items-center gap-3">
                        <div class="bg-white bg-opacity-25 rounded-circle d-flex align-items-center justify-content-center"
                             style="width:50px;height:50px;">
                            <i class="bi bi-cpu fs-4"></i>
                        </div>
                        <div>
                            <h5 class="mb-0 fw-bold">Sensor #@Model.SensorId</h5>
                            <small class="opacity-75">@Model.DeviceType Device</small>
                        </div>
                    </div>
                    <span class="badge @statusClass badge-status">
                        @Model.Status
                    </span>
                </div>

                <!-- Detail Rows -->
                <div class="card-body p-0">
                    <div class="detail-row">
                        <span class="detail-label"><i class="bi bi-hash me-2"></i>Sensor ID</span>
                        <span class="detail-value">@Model.SensorId</span>
                    </div>
                    <div class="detail-row">
                        <span class="detail-label"><i class="bi @typeIcon me-2"></i>Device Type</span>
                        <span class="detail-value">
                            <span class="badge @typeClass badge-status">
                                <i class="bi @typeIcon me-1"></i>@Model.DeviceType
                            </span>
                        </span>
                    </div>
                    <div class="detail-row">
                        <span class="detail-label"><i class="bi bi-box-seam me-2"></i>Assigned To</span>
                        <span class="detail-value">
                            @(string.IsNullOrWhiteSpace(Model.AssignedTo) ? "Not assigned" : Model.AssignedTo)
                        </span>
                    </div>
                    <div class="detail-row">
                        <span class="detail-label"><i class="bi bi-activity me-2"></i>Status</span>
                        <span class="detail-value">
                            <span class="badge @statusClass badge-status">@Model.Status</span>
                        </span>
                    </div>
                    <div class="detail-row">
                        <span class="detail-label"><i class="bi bi-reception-4 me-2"></i>Total Readings</span>
                        <span class="detail-value">
                            <span class="badge bg-info text-dark">
                                @Model.TelemetryRecords.Count reading(s)
                            </span>
                        </span>
                    </div>
                </div>

                <!-- Telemetry Preview (last 3 records) -->
                @if (Model.TelemetryRecords != null && Model.TelemetryRecords.Any())
                {
                    <div class="px-4 pb-3 pt-2">
                        <h6 class="fw-semibold text-muted mb-2 small text-uppercase letter-spacing-1">
                            <i class="bi bi-clock-history me-1"></i>Recent Readings
                        </h6>
                        <div class="table-responsive">
                            <table class="table table-sm table-bordered mb-0 rounded-3 overflow-hidden">
                                <thead class="table-light">
                                    <tr>
                                        <th class="small">Timestamp</th>
                                        <th class="small text-center">Temp (°C)</th>
                                        <th class="small text-center">Humidity (%)</th>
                                        <th class="small">Location</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var rec in Model.TelemetryRecords.OrderByDescending(t => t.Timestamp).Take(3))
                                    {
                                        <tr>
                                            <td class="small text-muted">@rec.Timestamp?.ToString("dd MMM yyyy HH:mm")</td>
                                            <td class="text-center small">
                                                @if (rec.Temperature.HasValue)
                                                {
                                                    @rec.Temperature?.ToString("F1")
                                                    if (rec.Temperature > 8)
                                                    {
                                                        <span class="badge bg-danger ms-1" style="font-size:0.6rem;">EXCURSION</span>
                                                    }
                                                    else if (rec.Temperature > 5)
                                                    {
                                                        <span class="badge bg-warning text-dark ms-1" style="font-size:0.6rem;">WARNING</span>
                                                    }
                                                }
                                                else { <span class="text-muted">—</span> }
                                            </td>
                                            <td class="text-center small">
                                                @(rec.Humidity.HasValue ? rec.Humidity?.ToString("F1") : "—")
                                            </td>
                                            <td class="small">@(string.IsNullOrWhiteSpace(rec.Location) ? "—" : rec.Location)</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                }

                <!-- Footer Actions -->
                <div class="card-footer bg-white border-top py-3 px-4 d-flex gap-2">
                    <a asp-action="Edit" asp-route-id="@Model.SensorId" class="btn btn-warning text-white fw-semibold">
                        <i class="bi bi-pencil me-1"></i>Edit
                    </a>
                    <a asp-controller="TelemetryRecord" asp-action="Index" class="btn btn-info text-white">
                        <i class="bi bi-thermometer-half me-1"></i>View Telemetry
                    </a>
                    <a asp-action="Index" class="btn btn-light">
                        <i class="bi bi-arrow-left me-1"></i>Back to List
                    </a>
                </div>
            </div>

        </div>
    </div>
</div>
