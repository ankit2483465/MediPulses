@model IEnumerable<WebApplication1.Models.SensorDevice>

@{
    ViewData["Title"] = "Sensor Devices";
}

<div class="container-fluid py-4 px-4">

    <!-- Page Header -->
    <div class="page-header mb-4" style="background: linear-gradient(135deg, #0dcaf0 0%, #0aa2c0 100%);">
        <div class="d-flex justify-content-between align-items-center flex-wrap gap-3">
            <div>
                <h2 class="mb-1"><i class="bi bi-cpu me-2"></i>Sensor Devices</h2>
                <nav aria-label="breadcrumb">
                    <ol class="breadcrumb mb-0">
                        <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Dashboard</a></li>
                        <li class="breadcrumb-item active">Sensor Devices</li>
                    </ol>
                </nav>
            </div>
            <a asp-action="Create" class="btn btn-light fw-semibold px-4 shadow-sm">
                <i class="bi bi-plus-lg me-1"></i>Add Sensor Device
            </a>
        </div>
    </div>

    <!-- Alerts -->
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show rounded-3 mb-4 shadow-sm" role="alert">
            <i class="bi bi-check-circle-fill me-2"></i>@TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (TempData["SuccessUpdate"] != null)
    {
        <div class="alert alert-info alert-dismissible fade show rounded-3 mb-4 shadow-sm" role="alert">
            <i class="bi bi-pencil-fill me-2"></i>@TempData["SuccessUpdate"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (TempData["SuccessDelete"] != null)
    {
        <div class="alert alert-warning alert-dismissible fade show rounded-3 mb-4 shadow-sm" role="alert">
            <i class="bi bi-trash-fill me-2"></i>@TempData["SuccessDelete"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <!-- Table Card -->
    <div class="data-card">
        <div class="card-header d-flex justify-content-between align-items-center flex-wrap gap-2">
            <span class="fw-semibold text-secondary small">
                <i class="bi bi-list-ul me-1"></i>All Sensor Devices
                <span class="badge bg-info text-dark ms-2">@Model.Count()</span>
            </span>
            <input type="text" id="searchInput" class="search-box" placeholder="Search devices..." style="width:260px;">
        </div>

        @if (Model.Any())
        {
            <div class="table-responsive">
                <table class="table" id="sensorTable">
                    <thead>
                        <tr>
                            <th style="width:50px">#</th>
                            <th>Sensor ID</th>
                            <th>Device Type</th>
                            <th>Assigned To</th>
                            <th>Status</th>
                            <th class="text-center"># Readings</th>
                            <th class="text-center" style="width:140px">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @{ int i = 1; }
                        @foreach (var item in Model)
                        {
                            var statusClass = item.Status switch {
                                "Active"      => "bg-success",
                                "Inactive"    => "bg-danger",
                                "Maintenance" => "bg-warning text-dark",
                                _             => "bg-secondary"
                            };
                            var typeClass = item.DeviceType switch {
                                "Temp"     => "bg-info text-dark",
                                "Humidity" => "bg-primary",
                                "GPS"      => "bg-secondary",
                                _          => "bg-secondary"
                            };
                            var typeIcon = item.DeviceType switch {
                                "Temp"     => "bi-thermometer-half",
                                "Humidity" => "bi-droplet-half",
                                "GPS"      => "bi-geo-alt-fill",
                                _          => "bi-cpu"
                            };
                            <tr>
                                <td class="text-muted">@i</td>
                                <td>
                                    <div class="d-flex align-items-center gap-2">
                                        <div class="avatar-icon bg-info bg-opacity-10 text-info rounded-circle d-flex align-items-center justify-content-center">
                                            <i class="bi bi-cpu"></i>
                                        </div>
                                        <span class="fw-semibold">Sensor #@item.SensorId</span>
                                    </div>
                                </td>
                                <td>
                                    <span class="badge @typeClass badge-status">
                                        <i class="bi @typeIcon me-1"></i>@item.DeviceType
                                    </span>
                                </td>
                                <td>
                                    <i class="bi bi-box-seam text-muted me-1"></i>
                                    @(string.IsNullOrWhiteSpace(item.AssignedTo) ? "—" : item.AssignedTo)
                                </td>
                                <td>
                                    <span class="badge @statusClass badge-status">
                                        @item.Status
                                    </span>
                                </td>
                                <td class="text-center">
                                    <span class="badge bg-light text-dark border">
                                        <i class="bi bi-reception-4 me-1 text-info"></i>@item.TelemetryRecords.Count
                                    </span>
                                </td>
                                <td class="text-center">
                                    <div class="d-flex justify-content-center gap-1">
                                        <a asp-action="Details" asp-route-id="@item.SensorId"
                                           class="btn btn-sm btn-outline-info" title="View Details">
                                            <i class="bi bi-eye-fill"></i>
                                        </a>
                                        <a asp-action="Edit" asp-route-id="@item.SensorId"
                                           class="btn btn-sm btn-outline-warning" title="Edit">
                                            <i class="bi bi-pencil-fill"></i>
                                        </a>
                                        <a asp-action="Delete" asp-route-id="@item.SensorId"
                                           class="btn btn-sm btn-outline-danger" title="Delete">
                                            <i class="bi bi-trash-fill"></i>
                                        </a>
                                    </div>
                                </td>
                            </tr>
                            i++;
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="empty-state">
                <i class="bi bi-cpu"></i>
                <p class="fw-semibold mb-1">No sensor devices found</p>
                <p class="small mb-3">Get started by registering your first sensor device.</p>
                <a asp-action="Create" class="btn btn-info text-white px-4">
                    <i class="bi bi-plus-lg me-1"></i>Add Sensor Device
                </a>
            </div>
        }
    </div>
</div>

@section Scripts {
    <script>
        document.getElementById('searchInput').addEventListener('keyup', function () {
            const filter = this.value.toLowerCase();
            document.querySelectorAll('#sensorTable tbody tr').forEach(row => {
                row.style.display = row.textContent.toLowerCase().includes(filter) ? '' : 'none';
            });
        });
    </script>
}
