@model WebApplication1.Models.Facility

@{
    ViewData["Title"] = "Add Facility";
}

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-md-7 col-lg-5">

            <nav aria-label="breadcrumb" class="mb-3">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index" class="text-decoration-none">Dashboard</a></li>
                    <li class="breadcrumb-item"><a asp-action="Index" class="text-decoration-none">Facilities</a></li>
                    <li class="breadcrumb-item active">Add New</li>
                </ol>
            </nav>

            <div class="form-card">
                <div class="card-header d-flex align-items-center gap-2"
                     style="background: linear-gradient(135deg, #198754 0%, #146c43 100%);">
                    <i class="bi bi-hospital fs-5"></i>
                    <h5 class="mb-0 fw-semibold">Add New Facility</h5>
                </div>
                <div class="card-body p-4">
                    <form asp-action="Create">
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 rounded-3 small mb-3"></div>

                        <div class="mb-3">
                            <label asp-for="Name" class="form-label">Facility Name <span class="text-danger">*</span></label>
                            <input asp-for="Name" class="form-control" placeholder="e.g. City General Hospital" />
                            <span asp-validation-for="Name" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Type" class="form-label">Facility Type <span class="text-danger">*</span></label>
                            <select asp-for="Type" class="form-select">
                                <option value="">-- Select Type --</option>
                                <option value="Hospital">Hospital</option>
                                <option value="Clinic">Clinic</option>
                                <option value="Warehouse">Warehouse</option>
                            </select>
                            <span asp-validation-for="Type" class="text-danger small"></span>
                        </div>

                        <div class="mb-4">
                            <label asp-for="Region" class="form-label">Region <span class="text-danger">*</span></label>
                            <input asp-for="Region" class="form-control" placeholder="e.g. North East" />
                            <span asp-validation-for="Region" class="text-danger small"></span>
                        </div>

                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-success px-4 fw-semibold">
                                <i class="bi bi-check2 me-1"></i>Create Facility
                            </button>
                            <a asp-action="Index" class="btn btn-light px-4">
                                <i class="bi bi-arrow-left me-1"></i>Cancel
                            </a>
                        </div>
                    </form>
                </div>
            </div>

        </div>
    </div>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}
